---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "The Orbital — Planetary Systems Governance",
  description = "Tracking the emergent movement for planetary systems governance. News, actors, and projects across ecology, technology, play, and democratic innovation.",
} = Astro.props;

const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content="The Orbital" />
  <meta property="og:description" content="Tracking the emergent movement for planetary systems governance." />
  <meta property="og:site_name" content="The Orbital" />
  <meta property="og:image" content="/assets/orbital_logo_4_v2a.png" />
  <link rel="icon" type="image/png" href="/assets/orbital_logo_4_v2a.png" />
  <link rel="alternate" type="application/rss+xml" title="The Orbital" href="/rss.xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;1,8..60,300&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- Masthead -->
  <header class="masthead">
    <a href="/" class="masthead-brand">
      <span class="masthead-title">THE ORBITAL</span>
      <span class="masthead-tagline">Tracking the emergent movement for planetary systems governance</span>
    </a>
  </header>

  <!-- Main nav -->
  <nav class="main-nav" id="main-nav">
    <div class="main-nav-inner">
      <div class="nav-links">
        <a href="/" class={currentPath === '/' ? 'active' : ''}>Feed</a>
        <a href="/actors" class={currentPath.startsWith('/actors') ? 'active' : ''}>Actors</a>
        <a href="/projects" class={currentPath.startsWith('/projects') ? 'active' : ''}>Projects</a>
        <a href="/events" class={currentPath.startsWith('/events') ? 'active' : ''}>Events</a>
        <a href="/graph" class={currentPath.startsWith('/graph') ? 'active' : ''}>Graph</a>
        <a href="/search" class={currentPath.startsWith('/search') ? 'active' : ''}>Search</a>
        <a href="/about" class={currentPath.startsWith('/about') ? 'active' : ''}>About</a>
        <a href="/contact" class={currentPath.startsWith('/contact') ? 'active' : ''}>Contact</a>
        <a href="/join" class="nav-join">Join →</a>
      </div>
      <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-logo">
        <img src="/assets/orbital_logo_4_v2a.png" alt="" class="footer-logo-img" />
        <span class="footer-logo-text">THE ORBITAL</span>
      </div>
      <p class="footer-tagline">Tracking the emergent movement for planetary systems governance.</p>
      <p class="footer-credits">
        <span class="footer-links">
          <a href="/about">About</a> · <a href="/contact">Contact</a>
        </span>
      </p>
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('nav-toggle');
    const nav = document.getElementById('main-nav');
    toggle?.addEventListener('click', () => nav?.classList.toggle('open'));
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';

  /* ── Masthead ── */
  .masthead {
    border-bottom: 3px double var(--border);
    padding: 2rem 1.25rem 1.5rem;
  }
  .masthead-brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: .5rem;
    text-decoration: none;
    max-width: var(--max-w);
    margin: 0 auto;
  }
  .masthead-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 3.5rem;
    font-weight: 600;
    letter-spacing: .22em;
    color: var(--text);
    line-height: 1;
    text-align: center;
  }
  .masthead-tagline {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: .9375rem;
    font-weight: 300;
    color: var(--text-2);
    letter-spacing: .04em;
    font-style: italic;
    text-align: center;
  }

  /* ── Main nav ── */
  .main-nav {
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 100;
  }
  .main-nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-links {
    display: flex;
    gap: 0;
  }
  .nav-links a {
    display: block;
    padding: .625rem 1rem;
    font-size: .8125rem;
    font-weight: 500;
    letter-spacing: .04em;
    text-transform: uppercase;
    color: var(--text-2);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: color .15s, border-color .15s;
  }
  .nav-links a:hover { color: var(--text); }
  .nav-links a.active { color: var(--text); border-bottom-color: var(--text); }
  .nav-join { color: var(--text) !important; font-weight: 600 !important; }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: .5rem 0;
  }
  .nav-toggle span { display: block; width: 22px; height: 2px; background: var(--text); border-radius: 2px; }

  @media (max-width: 640px) {
    .masthead-title { font-size: 2.25rem; letter-spacing: .14em; }
    .masthead-tagline { font-size: .8125rem; }

    .nav-toggle { display: flex; }
    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      flex-direction: column;
      padding: .5rem 0;
    }
    .main-nav.open .nav-links { display: flex; }
    .nav-links a { padding: .6rem 1.25rem; border-bottom: none; }
  }

  /* ── Footer ── */
  .site-footer {
    border-top: 3px double var(--border);
    padding: 2.5rem 0;
    margin-top: 5rem;
    color: var(--text-3);
  }
  .footer-inner { display: flex; flex-direction: column; align-items: center; gap: .875rem; text-align: center; }
  .footer-logo { display: flex; align-items: center; gap: .5rem; }
  .footer-logo-img { height: 28px; width: auto; opacity: .6; }
  .footer-logo-text { font-family: 'Playfair Display', Georgia, serif; font-size: .9rem; letter-spacing: .12em; color: var(--text-2); }
  .footer-tagline { font-size: .8125rem; color: var(--text-3); }
  .footer-credits { font-size: .8125rem; color: var(--text-3); line-height: 1.7; }
  .footer-credits a { color: var(--text-3); }
  .footer-credits a:hover { color: var(--text-2); }
  .footer-links { display: block; margin-top: .25rem; }

  main { padding-bottom: 2rem; }
</style>
