---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "The Orbital — Planetary Systems Governance",
  description = "Tracking the emergent movement for planetary systems governance. News, actors, and projects across ecology, technology, play, and democratic innovation.",
} = Astro.props;

const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content="The Orbital" />
  <meta property="og:description" content="Tracking the emergent movement for planetary systems governance." />
  <meta property="og:site_name" content="The Orbital" />
  <meta property="og:image" content="/assets/orbital_logo_4_v2a.png" />
  <link rel="icon" type="image/png" href="/assets/orbital_logo_4_v2a.png" />
  <link rel="alternate" type="application/rss+xml" title="The Orbital" href="/rss.xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;1,8..60,300&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- Masthead -->
  <header class="masthead">
    <!-- Orbital watermark -->
    <svg class="masthead-orrery" width="520" height="220" viewBox="0 0 520 220" fill="none" aria-hidden="true" focusable="false">
      <ellipse cx="260" cy="110" rx="248" ry="68" stroke="#2e5c3c" stroke-width="0.8" opacity="0.055"/>
      <ellipse cx="260" cy="110" rx="186" ry="50" stroke="#a35820" stroke-width="0.6" opacity="0.045"/>
      <ellipse cx="260" cy="110" rx="124" ry="33" stroke="#2e5c3c" stroke-width="0.6" opacity="0.04"/>
      <ellipse cx="260" cy="110" rx="66"  ry="18" stroke="#a35820" stroke-width="0.5" opacity="0.035"/>
      <circle cx="260" cy="110" r="5" fill="#2e5c3c" opacity="0.07"/>
      <circle cx="472" cy="97"  r="3.5" fill="#a35820" opacity="0.1"/>
      <circle cx="96"  cy="80"  r="2.5" fill="#2b606c" opacity="0.1"/>
      <circle cx="170" cy="67"  r="2"   fill="#4c3d6e" opacity="0.09"/>
    </svg>
    <a href="/" class="masthead-brand">
      <span class="masthead-title">THE ORBITAL</span>
      <span class="masthead-tagline">Tracking the emergent movement for planetary systems governance</span>
      <!-- Botanical ornament -->
      <span class="masthead-ornament" aria-hidden="true">
        <svg width="130" height="26" viewBox="0 0 130 26" fill="none" xmlns="http://www.w3.org/2000/svg">
          <line x1="0" y1="13" x2="42" y2="13" stroke="#cec4b0" stroke-width="0.8"/>
          <path d="M35 13 C33 8,27 6,24 8 C21 10,21 15,24 16 C27 17.5,33 16,35 13Z" fill="#4c7d5a" opacity="0.4"/>
          <path d="M42 13 C40 9,35 7.5,33 9.5 C31 11.5,31.5 15.5,33.5 16.5 C35.5 17.5,40 16,42 13Z" fill="#4c7d5a" opacity="0.28"/>
          <line x1="42" y1="13" x2="54" y2="13" stroke="#cec4b0" stroke-width="0.8"/>
          <line x1="76" y1="13" x2="88" y2="13" stroke="#cec4b0" stroke-width="0.8"/>
          <circle cx="65" cy="13" r="5" stroke="#a35820" stroke-width="0.8" fill="none" opacity="0.5"/>
          <circle cx="65" cy="13" r="2" fill="#a35820" opacity="0.35"/>
          <line x1="54" y1="13" x2="60" y2="13" stroke="#cec4b0" stroke-width="0.8"/>
          <line x1="70" y1="13" x2="76" y2="13" stroke="#cec4b0" stroke-width="0.8"/>
          <path d="M88 13 C90 9,95 7.5,97 9.5 C99 11.5,98.5 15.5,96.5 16.5 C94.5 17.5,90 16,88 13Z" fill="#4c7d5a" opacity="0.28"/>
          <path d="M95 13 C97 8,103 6,106 8 C109 10,109 15,106 16 C103 17.5,97 16,95 13Z" fill="#4c7d5a" opacity="0.4"/>
          <line x1="88" y1="13" x2="130" y2="13" stroke="#cec4b0" stroke-width="0.8"/>
        </svg>
      </span>
    </a>
  </header>

  <!-- Main nav -->
  <nav class="main-nav" id="main-nav">
    <div class="main-nav-inner">
      <div class="nav-links">
        <a href="/" class={currentPath === '/' ? 'active' : ''}>Feed</a>
        <a href="/stream" class={`admin-only ${currentPath.startsWith('/stream') ? 'active' : ''}`} id="nav-stream-link" style="display:none">Stream</a>
        <a href="/actors" class={currentPath.startsWith('/actors') ? 'active' : ''}>Actors</a>
        <a href="/projects" class={currentPath.startsWith('/projects') ? 'active' : ''}>Projects</a>
        <a href="/events" class={currentPath.startsWith('/events') ? 'active' : ''}>Events</a>
        <a href="/search" class={currentPath.startsWith('/search') ? 'active' : ''}>Search</a>
        <a href="/library" class={currentPath.startsWith('/library') ? 'active' : ''}>Library</a>
        <a href="/about" class={currentPath.startsWith('/about') ? 'active' : ''}>About</a>
        <a href="/contact" class={currentPath.startsWith('/contact') ? 'active' : ''}>Contact</a>
        <a href="/join" class="nav-join">Join →</a>
        <span class="nav-auth-wrap" id="nav-auth-wrap">
          <a href="/login" class="nav-auth-link" id="nav-auth-link">Sign in</a>
        </span>
      </div>
      <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-logo">
        <img src="/assets/orbital_logo_4_v2a.png" alt="" class="footer-logo-img" />
        <span class="footer-logo-text">THE ORBITAL</span>
      </div>
      <p class="footer-tagline">Tracking the emergent movement for planetary systems governance.</p>
      <div class="footer-links footer-credits">
        <a href="/about">About</a>
        <a href="/manifesto">Manifesto</a>
        <a href="/library">Library</a>
        <a href="/sources">Sources</a>
        <a href="/inclusion-policy">Inclusion Policy</a>
        <a href="/contact">Contact</a>
      </div>
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('nav-toggle');
    const nav = document.getElementById('main-nav');
    toggle?.addEventListener('click', () => nav?.classList.toggle('open'));
  </script>

  <script>
    // Client-side auth state + read counter — updates the nav on every page
    import { createClient } from '@supabase/supabase-js';

    const supabase = createClient(
      'https://lathlnothoosbwrvxtel.supabase.co',
      'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxhdGhsbm90aG9vc2J3cnZ4dGVsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzczNjU1OTYsImV4cCI6MjA5Mjk0MTU5Nn0.VZJxCAbOfpiepbvgq9m0xC2wMe0IgFNlUUUC9wbk3Gc',
      { auth: { persistSession: true, autoRefreshToken: true, detectSessionInUrl: false } },
    );
    (window as any).__supabase = supabase;

    function escapeHtml(s: string) {
      return s.replace(/[&<>"']/g, (c) => (
        { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string
      ));
    }

    async function renderSignedIn(user: any) {
      const wrap = document.getElementById('nav-auth-wrap');
      if (!wrap) return;
      const name = user.user_metadata?.full_name
        ?? user.user_metadata?.name
        ?? user.email?.split('@')[0]
        ?? 'Account';
      const avatar = user.user_metadata?.avatar_url ?? user.user_metadata?.picture ?? '';
      const initial = String(name).charAt(0).toUpperCase();

      // Read count
      let readCount = 0;
      try {
        const { count } = await supabase
          .from('reads')
          .select('id', { count: 'exact', head: true })
          .eq('user_id', user.id);
        readCount = count ?? 0;
      } catch {}

      wrap.innerHTML = `
        <div class="nav-user" title="Signed in as ${escapeHtml(name)}">
          <div class="nav-avatar" data-initial="${escapeHtml(initial)}">
            ${avatar ? `<img src="${escapeHtml(avatar)}" alt="" referrerpolicy="no-referrer" onerror="this.remove()" />` : ''}
          </div>
          <span class="nav-user-name">${escapeHtml(name)}</span>
          ${readCount > 0 ? `<span class="nav-read-count" title="${readCount} articles read">${readCount}✓</span>` : ''}
          <a href="/auth/signout" class="nav-signout" title="Sign out">↩</a>
        </div>
      `;
    }

    function renderSignedOut() {
      const wrap = document.getElementById('nav-auth-wrap');
      if (!wrap) return;
      wrap.innerHTML = `<a href="/login" class="nav-auth-link" id="nav-auth-link">Sign in</a>`;
    }

    async function applyAdminState(userId: string | null) {
      let isAdmin = false;
      if (userId) {
        try {
          const { data } = await supabase
            .from('user_profiles')
            .select('is_admin')
            .eq('id', userId)
            .maybeSingle();
          isAdmin = !!data?.is_admin;
        } catch {}
      }
      // Toggle .admin-only elements
      document.querySelectorAll<HTMLElement>('.admin-only').forEach(el => {
        el.style.display = isAdmin ? '' : 'none';
      });
      document.body.classList.toggle('is-admin', isAdmin);
      (window as any).__isAdmin = isAdmin;
      // Fire event so other scripts can react (e.g. tier-override UI)
      document.dispatchEvent(new CustomEvent('admin-state', { detail: { isAdmin } }));
    }

    async function updateAuthNav() {
      const { data: { session } } = await supabase.auth.getSession();
      if (session?.user) {
        await renderSignedIn(session.user);
        await applyAdminState(session.user.id);
      } else {
        renderSignedOut();
        await applyAdminState(null);
      }
    }

    updateAuthNav();
    supabase.auth.onAuthStateChange(() => updateAuthNav());

    // Re-render the read count when reads change elsewhere
    (window as any).__refreshAuthNav = updateAuthNav;
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';

  /* ── Masthead ── */
  .masthead {
    border-bottom: 1px solid var(--border);
    text-align: center;
    position: relative;
    overflow: hidden;
    /* Top accent rule */
    border-top: 3px solid transparent;
    background-clip: padding-box;
    box-shadow: inset 0 3px 0 0 var(--forest-2), inset 0 4px 0 0 var(--copper);
  }
  .masthead::after {
    content: '';
    position: absolute;
    bottom: 0; left: 50%; transform: translateX(-50%);
    width: 200px; height: 1px;
    background: linear-gradient(90deg, transparent, var(--copper), transparent);
    opacity: .3;
  }
  .masthead-orrery {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }
  .masthead-brand {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: .6rem;
    text-decoration: none;
    padding: 2.5rem 1.25rem 2rem;
    position: relative;
  }
  .masthead-brand:hover { text-decoration: none; }
  .masthead-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 4.25rem;
    font-weight: 600;
    letter-spacing: .26em;
    color: var(--forest);
    line-height: 1;
  }
  .masthead-tagline {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: .9rem;
    font-weight: 300;
    color: var(--text-3);
    letter-spacing: .04em;
    font-style: italic;
  }
  .masthead-ornament {
    display: block;
    line-height: 0;
    margin-top: .25rem;
  }

  /* ── Main nav ── */
  .main-nav {
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 100;
  }
  .main-nav-inner {
    max-width: var(--max-w-wide);
    margin: 0 auto;
    padding: 0 1.25rem;
    display: flex;
    align-items: stretch;
    justify-content: center;
  }
  .nav-links {
    display: flex;
    gap: 0;
    align-items: stretch;
  }
  .nav-links a {
    display: flex;
    align-items: center;
    padding: .5rem .65rem;
    font-size: .6875rem;
    font-weight: 600;
    letter-spacing: .07em;
    text-transform: uppercase;
    color: var(--text-3);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: color .15s, border-color .15s;
  }
  .nav-links a:hover { color: var(--text); text-decoration: none; }
  .nav-links a.active { color: var(--text); border-bottom-color: var(--text); }
  .nav-join {
    color: var(--text) !important;
    font-weight: 700 !important;
    margin-left: .25rem;
    border-left: 1px solid var(--border);
    padding-left: .875rem !important;
  }
  .nav-auth-wrap {
    display: flex;
    align-items: center;
    margin-left: .25rem;
    border-left: 1px solid var(--border);
    padding-left: .875rem;
  }
  .nav-auth-link {
    display: flex;
    align-items: center;
    font-size: .6875rem;
    font-weight: 600;
    letter-spacing: .07em;
    text-transform: uppercase;
    color: var(--text-3) !important;
    text-decoration: none;
    white-space: nowrap;
    transition: color .15s;
  }
  .nav-auth-link:hover { color: var(--text) !important; }

  .nav-user {
    display: flex;
    align-items: center;
    gap: .5rem;
  }
  .nav-avatar {
    --av: 24px;
    position: relative;
    width: var(--av); height: var(--av);
    border-radius: 50%;
    background: linear-gradient(135deg, #4a7c59, #2a6496);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    font-size: .6875rem;
    font-weight: 700;
    color: rgba(255,255,255,.95);
  }
  .nav-avatar::before {
    content: attr(data-initial);
    line-height: 1;
  }
  .nav-avatar img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }
  .nav-user-name {
    font-size: .75rem;
    font-weight: 600;
    color: var(--text);
    max-width: 130px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .nav-read-count {
    font-size: .625rem;
    font-weight: 700;
    color: #4a7c59;
    background: #e7f1ea;
    padding: .15rem .4rem;
    border-radius: 999px;
    letter-spacing: .03em;
  }
  .nav-signout {
    font-size: .8125rem;
    color: var(--text-3);
    text-decoration: none;
    opacity: .55;
    transition: opacity .15s, color .15s;
    flex-shrink: 0;
    padding: 0 .25rem;
  }
  .nav-signout:hover { opacity: 1; color: var(--text); }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: .5rem 0;
    margin-left: auto;
  }
  .nav-toggle span { display: block; width: 20px; height: 2px; background: var(--text); border-radius: 2px; }

  @media (max-width: 760px) {
    .masthead-title { font-size: 2.25rem; letter-spacing: .14em; }
    .masthead-tagline { font-size: .8125rem; }

    .nav-toggle { display: flex; }
    .main-nav-inner { justify-content: space-between; }
    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      flex-direction: column;
      padding: .375rem 0;
      box-shadow: 0 4px 12px rgba(0,0,0,.06);
    }
    .main-nav.open .nav-links { display: flex; }
    .nav-links a { padding: .6rem 1.25rem; border-bottom: none; font-size: .8rem; }
    .nav-join { border-left: none; margin-left: 0; padding-left: 1.25rem !important; }
    .nav-auth-wrap { border-left: none; margin-left: 0; padding-left: 1.25rem; }
    .nav-auth-link { max-width: none; }
  }

  /* ── Footer ── */
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 3rem 0 2.5rem;
    margin-top: 5rem;
  }
  .footer-inner { display: flex; flex-direction: column; align-items: center; gap: 1rem; text-align: center; }
  .footer-logo { display: flex; align-items: center; gap: .5rem; }
  .footer-logo-img { height: 26px; width: auto; opacity: .45; }
  .footer-logo-text { font-family: 'Playfair Display', Georgia, serif; font-size: .875rem; letter-spacing: .15em; color: var(--text-3); }
  .footer-tagline { font-size: .8125rem; color: var(--text-3); font-style: italic; }
  .footer-credits { font-size: .8125rem; color: var(--text-3); line-height: 1.9; }
  .footer-credits a { color: var(--text-3); text-decoration: none; }
  .footer-credits a:hover { color: var(--text-2); }
  .footer-links { display: flex; gap: 1.25rem; justify-content: center; flex-wrap: wrap; }

  main { padding-bottom: 2rem; }
</style>
