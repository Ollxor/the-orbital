---
import Base from '../layouts/Base.astro';
import actorsData from '../data/actors.json';
import regionsData from '../data/regions.json';

const orientationLabels: Record<string, string> = {
  GARDEN:   'The Garden',
  SPACESHIP:'Spaceship Earth',
  MYSTERIES:'The Mysteries',
  ASSEMBLY: 'The Assemblies',
};
const iconMap: Record<string, string> = {
  GARDEN:   'Icons2-01.svg',
  SPACESHIP:'Icons2-04.svg',
  MYSTERIES:'Icons2-03.svg',
  ASSEMBLY: 'Icons2-02.svg',
};
const accentMap: Record<string, string> = {
  GARDEN:   '#4a7c59',
  SPACESHIP:'#2a6496',
  MYSTERIES:'#7b5ea7',
  ASSEMBLY: '#b8860b',
};
const orientations = ['GARDEN','SPACESHIP','MYSTERIES','ASSEMBLY'] as const;

// ── Type filter ──────────────────────────────────────────────────────────────
const MAIN_TYPES = ['NGO','Network','Company','Research','Government','Movement'];
const ALL_TYPES  = [...MAIN_TYPES, 'Other'];
function normalizeType(t: string): string {
  return MAIN_TYPES.includes(t) ? t : 'Other';
}

// ── Continent filter — counts from data, always show all ─────────────────────
const CONTINENT_ORDER = ['africa','north-america','latin-america','asia','europe','oceania','transnational'] as const;
type Continent = typeof CONTINENT_ORDER[number];

const continentCounts: Record<string, number> = {};
CONTINENT_ORDER.forEach(c => { continentCounts[c] = 0; });
(actorsData as any[]).forEach((a: any) => {
  if (a.continent) continentCounts[a.continent] = (continentCounts[a.continent] ?? 0) + 1;
});

// ── Scale filter ─────────────────────────────────────────────────────────────
const SCALE_ORDER = ['local','regional','national','continental','global'] as const;
const scaleCounts: Record<string, number> = {};
SCALE_ORDER.forEach(s => { scaleCounts[s] = 0; });
(actorsData as any[]).forEach((a: any) => {
  const s = (a.scale ?? '').toLowerCase();
  if (s) scaleCounts[s] = (scaleCounts[s] ?? 0) + 1;
});

// ── Featured rotation queue ──────────────────────────────────────────────────
const featuredQueue: string[][] = [
  ['rth',                        'global-assembly',              'gaia-foundation'],
  ['dark-matter-labs',           'sortition-foundation',         'rewilding-europe'],
  ['doughnut-economics-action-lab','polis',                      'long-now-foundation'],
  ['regen-network',              'radicalxchange',               'theatre-of-the-oppressed-nyc'],
  ['climate-trace',              'world-social-forum',           'the-borderland'],
  ['beckley-foundation',         'p2p-foundation',               'ecosystem-restoration-communities'],
  ['metagov',                    'earth-law-center',             'demos-helsinki'],
  ['plurality-institute',        'transition-network',           'superflux'],
  ['sitra',                      'global-rewilding-alliance',    'co-intelligence-institute'],
  ['g0v',                        'climate-justice-alliance',     'ritual-design-lab'],
  ['future-earth',               'steward-ownership',            'institute-for-futures-studies'],
  ['refi-dao',                   'saami-council',                'global-tapestry-of-alternatives'],
];
const actorMap = Object.fromEntries((actorsData as any[]).map((a: any) => [a.slug, a]));

function getFavicon(website: string): string {
  if (!website) return '';
  try {
    const url = new URL(website);
    return `https://icons.duckduckgo.com/ip3/${url.hostname}.ico`;
  } catch { return ''; }
}
---

<Base title="Actors — The Orbital">
  <div class="actors-page">

    <div class="actors-header">
      <h1 class="actors-title">Actors</h1>
      <p class="actors-desc">Organisations, networks, and initiatives building pieces of the planetary governance movement.</p>
    </div>

    <!-- Transparency note -->
    <p class="representation-note">
      This index is a work in progress and currently over-represents actors from Europe and the Americas.
      We're actively expanding our sources for Africa, Asia, and Oceania.
      See <a href="/sources">Sources</a> for the directories we reference, or <a href="/contact">get in touch</a> to contribute.
    </p>

    <!-- Orientation filter -->
    <div class="filter-bar" id="filter-bar">
      {orientations.map(key => (
        <button class="filter-btn active" data-orientation={key} aria-pressed="true">
          <img src={`/assets/${iconMap[key]}`} alt={orientationLabels[key]} class="filter-icon" />
          <span class="filter-label">{orientationLabels[key]}</span>
        </button>
      ))}
    </div>

    <!-- Continent · Scale · Type secondary filters -->
    <div class="secondary-filters" id="secondary-filters">

      <div class="filter-row">
        <span class="filter-row-label">Continent</span>
        <div class="filter-row-pills">
          {CONTINENT_ORDER.map(c => {
            const label = (regionsData.continents as any)[c]?.name ?? c;
            const count = continentCounts[c] ?? 0;
            return (
              <button
                class="pill-btn active continent-btn"
                data-continent={c}
                aria-pressed="true"
                title={`${label} — ${count} actor${count !== 1 ? 's' : ''}`}
              >
                {label} <span class="pill-count">({count})</span>
              </button>
            );
          })}
        </div>
      </div>

      <div class="filter-row">
        <span class="filter-row-label">Scale</span>
        <div class="filter-row-pills">
          {SCALE_ORDER.map(s => {
            const count = scaleCounts[s] ?? 0;
            const label = s.charAt(0).toUpperCase() + s.slice(1);
            return (
              <button
                class="pill-btn active scale-btn"
                data-scale={s}
                aria-pressed="true"
                title={`${label} — ${count} actor${count !== 1 ? 's' : ''}`}
              >
                {label} <span class="pill-count">({count})</span>
              </button>
            );
          })}
        </div>
      </div>

      <div class="filter-row">
        <span class="filter-row-label">Type</span>
        <div class="filter-row-pills">
          {ALL_TYPES.map(t => (
            <button class="pill-btn active type-btn" data-type={t} aria-pressed="true">{t}</button>
          ))}
        </div>
      </div>

    </div>

    <!-- Featured this week -->
    <div class="featured-section" id="featured-section">
      <div class="featured-header">
        <span class="featured-dot"></span>
        <span class="featured-label">Featured this week</span>
      </div>
      <div class="featured-grid" id="featured-grid">
        {featuredQueue.map((set, setIdx) => (
          set.map(slug => {
            const actor = actorMap[slug];
            if (!actor) return null;
            const accent = accentMap[(actor as any).orientations[0]] ?? '#999';
            const favicon = getFavicon((actor as any).website);
            return (
              <a
                href={`/actors/${(actor as any).slug}`}
                class="featured-card"
                data-set={setIdx}
                style={`--accent:${accent};display:none`}
              >
                <div class="card-orientations">
                  {(actor as any).orientations.map((o: string) => (
                    <img src={`/assets/${iconMap[o]}`} alt={orientationLabels[o]} class="card-orient-icon" title={orientationLabels[o]} />
                  ))}
                </div>
                <div class="card-name-row">
                  {favicon && (
                    <img src={favicon} alt="" class="card-favicon" referrerpolicy="no-referrer" onerror="this.style.display='none'" loading="lazy" />
                  )}
                  <h3 class="card-name">{(actor as any).name}</h3>
                </div>
                <p class="card-desc featured-desc">{(actor as any).description}</p>
                <div class="card-footer">
                  {(actor as any).type && <span class="card-type">{(actor as any).type}</span>}
                  {(actor as any).location && (actor as any).type && <span class="card-sep">·</span>}
                  {(actor as any).location && <span class="card-loc">{(actor as any).location}</span>}
                </div>
              </a>
            );
          })
        ))}
      </div>
    </div>

    <!-- Search + count -->
    <div class="search-row">
      <input type="search" id="actor-search" placeholder="Search actors…" class="search-input" />
      <span class="actor-count" id="actor-count">{actorsData.length} actors</span>
    </div>

    <!-- Grid -->
    <div class="actors-grid" id="actors-grid">
      {(actorsData as any[]).map((actor: any) => {
        const primaryOrientation = actor.orientations[0];
        const accent = accentMap[primaryOrientation] ?? '#999';
        const favicon = getFavicon(actor.website);
        const actorType = normalizeType(actor.type);
        const actorScale = (actor.scale ?? '').toLowerCase();
        return (
          <a
            href={`/actors/${actor.slug}`}
            class="actor-card"
            id={actor.slug}
            data-orientations={actor.orientations.join(',')}
            data-name={actor.name.toLowerCase()}
            data-desc={actor.description?.toLowerCase() ?? ''}
            data-type={actorType}
            data-continent={actor.continent ?? ''}
            data-scale={actorScale}
            style={`--accent:${accent}`}
          >
            <div class="card-orientations">
              {actor.orientations.map((o: string) => (
                <img src={`/assets/${iconMap[o]}`} alt={orientationLabels[o]} class="card-orient-icon" title={orientationLabels[o]} />
              ))}
            </div>
            <div class="card-name-row">
              {favicon && (
                <img src={favicon} alt="" class="card-favicon" referrerpolicy="no-referrer" onerror="this.style.display='none'" loading="lazy" />
              )}
              <h3 class="card-name">{actor.name}</h3>
            </div>
            <p class="card-desc">{actor.description}</p>
            <div class="card-footer">
              {actor.type && <span class="card-type">{actor.type}</span>}
              {actor.location && actor.type && <span class="card-sep">·</span>}
              {actor.location && <span class="card-loc">{actor.location}</span>}
            </div>
          </a>
        );
      })}
    </div>

    <p class="no-results" id="no-results" style="display:none">No actors match your current filters.</p>
  </div>
</Base>

<style>
/* ── Page wrapper ── */
.actors-page {
  max-width: 1300px;
  margin: 0 auto;
  padding: 2rem 2rem 4rem;
}

/* ── Header ── */
.actors-header { padding-bottom: 1rem; }
.actors-title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 2rem;
  font-weight: 400;
  margin-bottom: .5rem;
}
.actors-desc { font-size: .9375rem; color: var(--text-2); }

/* ── Transparency note ── */
.representation-note {
  font-size: .8125rem;
  color: var(--text-3);
  line-height: 1.6;
  margin: .75rem 0 1.5rem;
  font-style: italic;
}
.representation-note a { color: var(--text-2); font-weight: 600; text-decoration: none; }
.representation-note a:hover { text-decoration: underline; }

/* ── Orientation filter bar ── */
.filter-bar {
  display: flex;
  justify-content: center;
  gap: 2.5rem;
  flex-wrap: wrap;
  align-items: flex-start;
  padding: 1rem 1.5rem;
  background: var(--filter-bg);
  border-radius: 10px 10px 0 0;
  border-bottom: 1px solid var(--border);
}
.filter-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .35rem;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  opacity: 1;
  transition: transform .15s, opacity .15s;
}
.filter-btn:hover { transform: scale(1.08); }
.filter-btn:not(.active) { opacity: .28; }
.filter-icon { width: 32px; height: 32px; object-fit: contain; }
.filter-label { font-size: .6875rem; color: var(--text-3); white-space: nowrap; letter-spacing: .04em; }

/* ── Secondary filters ── */
.secondary-filters {
  display: flex;
  flex-direction: column;
  gap: .375rem;
  padding: .75rem 1.25rem;
  background: var(--filter-bg);
  border-radius: 0 0 10px 10px;
  margin-bottom: 1.75rem;
}
.filter-row {
  display: flex;
  align-items: center;
  gap: .5rem;
  flex-wrap: wrap;
}
.filter-row-label {
  font-family: var(--font-sans);
  font-size: .625rem;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--text-3);
  min-width: 58px;
  flex-shrink: 0;
}
.filter-row-pills {
  display: flex;
  flex-wrap: wrap;
  gap: .3rem;
}
.pill-btn {
  font-size: .6875rem;
  font-weight: 500;
  padding: .2rem .625rem;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: var(--bg);
  color: var(--text-3);
  cursor: pointer;
  transition: background .12s, color .12s, border-color .12s;
  line-height: 1.5;
  white-space: nowrap;
}
.pill-btn:hover { border-color: var(--text-2); color: var(--text-2); }
.pill-btn.active {
  background: var(--text);
  color: var(--bg);
  border-color: var(--text);
}
.pill-btn.active:hover { opacity: .85; }
/* Zero-count continent buttons — always visible but subtly muted */
.pill-btn[data-count="0"]:not(.active) { opacity: .5; }
.pill-count { opacity: .65; font-size: .625rem; }
.pill-btn.active .pill-count { opacity: .8; }

/* ── Featured this week ── */
.featured-section { margin-bottom: 2rem; }
.featured-header { display: flex; align-items: center; gap: .5rem; margin-bottom: 1rem; }
.featured-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--text-3); opacity: .5; flex-shrink: 0; }
.featured-label {
  font-family: var(--font-sans);
  font-size: .6875rem;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--text-3);
}
.featured-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.75rem;
}
@media (max-width: 900px) { .featured-grid { grid-template-columns: 1fr; } }

.featured-card {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: .875rem;
  padding: 1.75rem 1.75rem 1.375rem;
  border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--border));
  border-left: 3px solid var(--accent, var(--border));
  border-radius: 0 10px 10px 0;
  background: color-mix(in srgb, var(--accent) 4%, var(--bg));
  text-decoration: none;
  color: inherit;
  transition: box-shadow .2s, transform .2s, border-color .2s;
  cursor: pointer;
}
.featured-card:hover {
  box-shadow: 0 6px 24px rgba(0,0,0,.1);
  transform: translateY(-2px);
  border-color: color-mix(in srgb, var(--accent) 60%, var(--border));
  text-decoration: none;
}

/* ── Search row ── */
.search-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 2rem;
}
.search-input {
  flex: 1;
  max-width: 360px;
  padding: .5rem .875rem;
  border: 1px solid var(--border);
  border-radius: 6px;
  background: var(--bg);
  font-size: .875rem;
  color: var(--text);
  outline: none;
  transition: border-color .15s;
}
.search-input:focus { border-color: var(--text-2); }
.actor-count { font-size: .8125rem; color: var(--text-3); }

/* ── Grid ── */
.actors-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.75rem;
}
@media (max-width: 1050px) { .actors-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 600px)  { .actors-grid { grid-template-columns: 1fr; } }

/* ── Actor card ── */
.actor-card {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: .875rem;
  padding: 1.75rem 1.75rem 1.375rem;
  border: 1px solid var(--border);
  border-left: 3px solid var(--accent, var(--border));
  border-radius: 0 10px 10px 0;
  background: var(--bg);
  text-decoration: none;
  color: inherit;
  transition: box-shadow .2s, transform .2s, border-color .2s;
  cursor: pointer;
}
.actor-card:hover {
  box-shadow: 0 6px 20px rgba(0,0,0,.08);
  transform: translateY(-2px);
  border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
  text-decoration: none;
}
.actor-card.hidden { display: none; }

/* ── Shared card elements ── */
.card-orientations { position: absolute; top: 1.25rem; right: 1.25rem; display: flex; gap: .3rem; }
.card-orient-icon { width: 20px; height: 20px; object-fit: contain; opacity: .85; }
.card-name-row { display: flex; align-items: center; gap: .625rem; padding-right: 3.5rem; }
.card-favicon { width: 22px; height: 22px; object-fit: contain; border-radius: 3px; flex-shrink: 0; opacity: .8; }
.card-name {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 1.0625rem;
  font-weight: 400;
  line-height: 1.3;
  color: var(--text);
}
.card-desc {
  font-size: .875rem;
  line-height: 1.65;
  color: var(--text-2);
  flex: 1;
  display: -webkit-box;
  -webkit-line-clamp: 5;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.featured-desc { -webkit-line-clamp: unset; overflow: visible; display: block; }
.card-footer { display: flex; align-items: center; gap: .375rem; padding-top: .25rem; border-top: 1px solid var(--border); margin-top: auto; }
.card-type { font-size: .6875rem; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; color: var(--accent, var(--text-3)); }
.card-sep  { font-size: .6875rem; color: var(--text-3); }
.card-loc  { font-size: .6875rem; color: var(--text-3); }

/* ── No results ── */
.no-results { color: var(--text-3); font-size: .9375rem; padding: 2rem 0; }
</style>

<script>
// ── Featured rotation ────────────────────────────────────────────────────────
const allFeaturedCards = document.querySelectorAll<HTMLElement>('.featured-card');
const sets = new Set<string>();
allFeaturedCards.forEach(c => sets.add(c.dataset.set!));
const weeksSinceEpoch = Math.floor(Date.now() / (7 * 24 * 60 * 60 * 1000));
const currentSet = String(weeksSinceEpoch % sets.size);
allFeaturedCards.forEach(card => {
  if (card.dataset.set === currentSet) card.style.display = 'flex';
});

// ── DOM refs ─────────────────────────────────────────────────────────────────
const filterBtns   = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
const continentBtns= document.querySelectorAll<HTMLButtonElement>('.continent-btn');
const scaleBtns    = document.querySelectorAll<HTMLButtonElement>('.scale-btn');
const typeBtns     = document.querySelectorAll<HTMLButtonElement>('.type-btn');
const cards        = document.querySelectorAll<HTMLElement>('.actor-card');
const searchInput  = document.getElementById('actor-search') as HTMLInputElement | null;
const countEl      = document.getElementById('actor-count');
const noResults    = document.getElementById('no-results');

// ── Helpers ──────────────────────────────────────────────────────────────────
function activeSet(buttons: NodeListOf<HTMLButtonElement>, attr: string): Set<string> {
  const s = new Set<string>();
  buttons.forEach(b => { if (b.classList.contains('active')) s.add(b.dataset[attr]!); });
  return s;
}

function syncButtons(buttons: NodeListOf<HTMLButtonElement>, attr: string, values: string[] | null) {
  if (!values) return;
  buttons.forEach(b => {
    const on = values.includes(b.dataset[attr]!);
    b.classList.toggle('active', on);
    b.setAttribute('aria-pressed', on ? 'true' : 'false');
  });
}

// ── Init from URL ─────────────────────────────────────────────────────────────
(function initFromURL() {
  const p = new URLSearchParams(location.search);
  syncButtons(filterBtns,    'orientation', p.get('o')?.split(',').filter(Boolean) ?? null);
  syncButtons(continentBtns, 'continent',   p.get('c')?.split(',').filter(Boolean) ?? null);
  syncButtons(scaleBtns,     'scale',       p.get('s')?.split(',').filter(Boolean) ?? null);
  syncButtons(typeBtns,      'type',        p.get('t')?.split(',').filter(Boolean) ?? null);
  if (p.get('q') && searchInput) searchInput.value = p.get('q')!;
})();

// ── URL update ────────────────────────────────────────────────────────────────
function pushURL(ao: Set<string>, ac: Set<string>, as_: Set<string>, at: Set<string>, q: string) {
  const p = new URLSearchParams();
  if (ao.size > 0 && ao.size < filterBtns.length)    p.set('o', [...ao].join(','));
  if (ac.size > 0 && ac.size < continentBtns.length)  p.set('c', [...ac].join(','));
  if (as_.size > 0 && as_.size < scaleBtns.length)    p.set('s', [...as_].join(','));
  if (at.size > 0 && at.size < typeBtns.length)       p.set('t', [...at].join(','));
  if (q) p.set('q', q);
  const qs = p.toString();
  history.replaceState(null, '', qs ? `?${qs}` : location.pathname);
}

// ── Visibility ────────────────────────────────────────────────────────────────
function updateVisibility() {
  const ao  = activeSet(filterBtns,    'orientation');
  const ac  = activeSet(continentBtns, 'continent');
  const as_ = activeSet(scaleBtns,     'scale');
  const at  = activeSet(typeBtns,      'type');
  const q   = (searchInput?.value ?? '').toLowerCase().trim();

  pushURL(ao, ac, as_, at, q);

  let visible = 0;
  cards.forEach(card => {
    const orients = (card.dataset.orientations ?? '').split(',');
    const matchO = orients.some(o => ao.has(o));
    const matchC = ac.has(card.dataset.continent ?? '');
    const matchS = as_.has(card.dataset.scale ?? '');
    const matchT = at.has(card.dataset.type ?? '');
    const matchQ = !q || (card.dataset.name ?? '').includes(q) || (card.dataset.desc ?? '').includes(q);
    const show = matchO && matchC && matchS && matchT && matchQ;
    card.classList.toggle('hidden', !show);
    if (show) visible++;
  });

  if (countEl) countEl.textContent = `${visible} actor${visible !== 1 ? 's' : ''}`;
  if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
}

// ── Wire all filter groups ────────────────────────────────────────────────────
function wireFilter(buttons: NodeListOf<HTMLButtonElement>, attr: string) {
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      btn.classList.toggle('active');
      btn.setAttribute('aria-pressed', btn.classList.contains('active') ? 'true' : 'false');
      if (activeSet(buttons, attr).size === 0) {
        buttons.forEach(b => { b.classList.add('active'); b.setAttribute('aria-pressed', 'true'); });
      }
      updateVisibility();
    });
  });
}

wireFilter(filterBtns,    'orientation');
wireFilter(continentBtns, 'continent');
wireFilter(scaleBtns,     'scale');
wireFilter(typeBtns,      'type');
searchInput?.addEventListener('input', updateVisibility);

updateVisibility();
</script>
