---
import Base from '../layouts/Base.astro';
import actorsData from '../data/actors.json';

const orientationLabels: Record<string, string> = {
  GARDEN:   'The Garden',
  SPACESHIP:'Spaceship Earth',
  MYSTERIES:'The Mysteries',
  ASSEMBLY: 'The Assemblies',
};
const iconMap: Record<string, string> = {
  GARDEN:   'Icons2-01.svg',
  SPACESHIP:'Icons2-04.svg',
  MYSTERIES:'Icons2-03.svg',
  ASSEMBLY: 'Icons2-02.svg',
};
// Primary orientation accent colours (match global.css vars)
const accentMap: Record<string, string> = {
  GARDEN:   '#4a7c59',
  SPACESHIP:'#2a6496',
  MYSTERIES:'#7b5ea7',
  ASSEMBLY: '#b8860b',
};
const orientations = ['GARDEN','SPACESHIP','MYSTERIES','ASSEMBLY'] as const;

function getFavicon(website: string): string {
  if (!website) return '';
  try {
    const url = new URL(website);
    return `https://icons.duckduckgo.com/ip3/${url.hostname}.ico`;
  } catch { return ''; }
}
---

<Base title="Actors — The Orbital">
  <div class="actors-page">

    <div class="actors-header">
      <h1 class="actors-title">Actors</h1>
      <p class="actors-desc">Organisations, networks, and initiatives building pieces of the planetary governance movement.</p>
    </div>

    <!-- Orientation filter — centred -->
    <div class="filter-bar" id="filter-bar">
      {orientations.map(key => (
        <button class="filter-btn active" data-orientation={key} aria-pressed="true">
          <img src={`/assets/${iconMap[key]}`} alt={orientationLabels[key]} class="filter-icon" />
          <span class="filter-label">{orientationLabels[key]}</span>
        </button>
      ))}
    </div>

    <!-- Search + count -->
    <div class="search-row">
      <input type="search" id="actor-search" placeholder="Search actors…" class="search-input" />
      <span class="actor-count" id="actor-count">{actorsData.length} actors</span>
    </div>

    <!-- Grid -->
    <div class="actors-grid" id="actors-grid">
      {actorsData.map(actor => {
        const primaryOrientation = actor.orientations[0];
        const accent = accentMap[primaryOrientation] ?? '#999';
        const favicon = getFavicon(actor.website);
        return (
          <a
            href={`/actors/${actor.slug}`}
            class="actor-card"
            id={actor.slug}
            data-orientations={actor.orientations.join(',')}
            data-name={actor.name.toLowerCase()}
            style={`--accent:${accent}`}
          >
            <!-- Orientation icons, top-right -->
            <div class="card-orientations">
              {actor.orientations.map(o => (
                <img
                  src={`/assets/${iconMap[o]}`}
                  alt={orientationLabels[o]}
                  class="card-orient-icon"
                  title={orientationLabels[o]}
                />
              ))}
            </div>

            <!-- Name row with favicon -->
            <div class="card-name-row">
              {favicon && (
                <img
                  src={favicon}
                  alt=""
                  class="card-favicon"
                  referrerpolicy="no-referrer"
                  onerror="this.style.display='none'"
                  loading="lazy"
                />
              )}
              <h3 class="card-name">{actor.name}</h3>
            </div>

            <!-- Description -->
            <p class="card-desc">{actor.description}</p>

            <!-- Footer: type · location -->
            <div class="card-footer">
              {actor.type && <span class="card-type">{actor.type}</span>}
              {actor.location && actor.type && <span class="card-sep">·</span>}
              {actor.location && <span class="card-loc">{actor.location}</span>}
            </div>
          </a>
        );
      })}
    </div>

    <p class="no-results" id="no-results" style="display:none">No actors match your current filters.</p>
  </div>
</Base>

<style>
/* ── Page wrapper — wide, breaks out of 720px container ── */
.actors-page {
  max-width: 1300px;
  margin: 0 auto;
  padding: 2rem 2rem 4rem;
}

/* ── Header ── */
.actors-header { padding-bottom: 1.75rem; }
.actors-title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 2rem;
  font-weight: 400;
  margin-bottom: .5rem;
}
.actors-desc { font-size: .9375rem; color: var(--text-2); }

/* ── Filter bar — centred ── */
.filter-bar {
  display: flex;
  justify-content: center;
  gap: 2.5rem;
  flex-wrap: wrap;
  align-items: flex-start;
  padding: 1rem 1.5rem;
  background: var(--filter-bg);
  border-radius: 10px;
  margin-bottom: 1.25rem;
}
.filter-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .35rem;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  opacity: 1;
  transition: transform .15s, opacity .15s;
}
.filter-btn:hover { transform: scale(1.08); }
.filter-btn:not(.active) { opacity: .28; }
.filter-icon { width: 32px; height: 32px; object-fit: contain; }
.filter-label { font-size: .6875rem; color: var(--text-3); white-space: nowrap; letter-spacing: .04em; }

/* ── Search row ── */
.search-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 2rem;
}
.search-input {
  flex: 1;
  max-width: 360px;
  padding: .5rem .875rem;
  border: 1px solid var(--border);
  border-radius: 6px;
  background: var(--bg);
  font-size: .875rem;
  color: var(--text);
  outline: none;
  transition: border-color .15s;
}
.search-input:focus { border-color: var(--text-2); }
.actor-count { font-size: .8125rem; color: var(--text-3); }

/* ── Grid ── */
.actors-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.75rem;
}
@media (max-width: 1050px) { .actors-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 600px)  { .actors-grid { grid-template-columns: 1fr; } }

/* ── Actor card ── */
.actor-card {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: .875rem;
  padding: 1.75rem 1.75rem 1.375rem;
  border: 1px solid var(--border);
  border-left: 3px solid var(--accent, var(--border));
  border-radius: 0 10px 10px 0;
  background: var(--bg);
  text-decoration: none;
  color: inherit;
  transition: box-shadow .2s, transform .2s, border-color .2s;
  cursor: pointer;
}
.actor-card:hover {
  box-shadow: 0 6px 20px rgba(0,0,0,.08);
  transform: translateY(-2px);
  border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
  text-decoration: none;
}
.actor-card.hidden { display: none; }

/* ── Orientation icons — top right corner ── */
.card-orientations {
  position: absolute;
  top: 1.25rem;
  right: 1.25rem;
  display: flex;
  gap: .3rem;
}
.card-orient-icon { width: 20px; height: 20px; object-fit: contain; opacity: .85; }

/* ── Name row ── */
.card-name-row {
  display: flex;
  align-items: center;
  gap: .625rem;
  padding-right: 3.5rem; /* avoid overlap with orientation icons */
}
.card-favicon {
  width: 22px;
  height: 22px;
  object-fit: contain;
  border-radius: 3px;
  flex-shrink: 0;
  opacity: .8;
}
.card-name {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 1.0625rem;
  font-weight: 400;
  line-height: 1.3;
  color: var(--text);
}

/* ── Description ── */
.card-desc {
  font-size: .875rem;
  line-height: 1.65;
  color: var(--text-2);
  flex: 1;
  /* Clamp to 5 lines */
  display: -webkit-box;
  -webkit-line-clamp: 5;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ── Card footer ── */
.card-footer {
  display: flex;
  align-items: center;
  gap: .375rem;
  padding-top: .25rem;
  border-top: 1px solid var(--border);
  margin-top: auto;
}
.card-type { font-size: .6875rem; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; color: var(--accent, var(--text-3)); }
.card-sep  { font-size: .6875rem; color: var(--text-3); }
.card-loc  { font-size: .6875rem; color: var(--text-3); }

/* ── No results ── */
.no-results { color: var(--text-3); font-size: .9375rem; padding: 2rem 0; }
</style>

<script>
const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
const cards = document.querySelectorAll<HTMLElement>('.actor-card');
const searchInput = document.getElementById('actor-search') as HTMLInputElement | null;
const countEl = document.getElementById('actor-count');
const noResults = document.getElementById('no-results');

function updateVisibility() {
  const active = new Set<string>();
  filterBtns.forEach(b => { if (b.classList.contains('active')) active.add(b.dataset.orientation!); });
  const query = (searchInput?.value ?? '').toLowerCase();
  let visible = 0;

  cards.forEach(card => {
    const orients = (card.dataset.orientations ?? '').split(',');
    const name = card.dataset.name ?? '';
    const matchFilter = orients.some(o => active.has(o));
    const matchSearch = !query || name.includes(query);
    const show = matchFilter && matchSearch;
    card.classList.toggle('hidden', !show);
    if (show) visible++;
  });

  if (countEl) countEl.textContent = `${visible} actor${visible !== 1 ? 's' : ''}`;
  if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
}

filterBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    btn.classList.toggle('active');
    btn.setAttribute('aria-pressed', btn.classList.contains('active') ? 'true' : 'false');
    const active = new Set<string>();
    filterBtns.forEach(b => { if (b.classList.contains('active')) active.add(b.dataset.orientation!); });
    // If all deselected, re-select all
    if (active.size === 0) filterBtns.forEach(b => { b.classList.add('active'); b.setAttribute('aria-pressed', 'true'); });
    updateVisibility();
  });
});

searchInput?.addEventListener('input', updateVisibility);
</script>
