---
import Base from '../../layouts/Base.astro';
import actorsData from '../../data/actors.json';
import newsData from '../../data/news.json';
import projectsData from '../../data/projects.json';
import eventsData from '../../data/events.json';

export function getStaticPaths() {
  return actorsData.map(a => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const actor = actorsData.find(a => a.slug === slug)!;

function getLogo(website: string): string {
  if (!website) return '';
  try {
    const url = new URL(website);
    return `https://logo.clearbit.com/${url.hostname}`;
  } catch {
    return '';
  }
};

const orientationLabels: Record<string, string> = {
  GARDEN: 'The Garden',
  SPACESHIP: 'Spaceship Earth',
  MYSTERIES: 'The Mysteries',
  ASSEMBLY: 'The Assemblies',
};
const iconMap: Record<string, string> = {
  GARDEN: 'Icons2-01.svg',
  SPACESHIP: 'Icons2-04.svg',
  MYSTERIES: 'Icons2-03.svg',
  ASSEMBLY: 'Icons2-02.svg',
};

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}

const relatedNews = newsData
  .filter(n => n.actors?.includes(slug!))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const relatedProjects = projectsData.filter(p => p.actors?.includes(slug!));
const relatedEvents = eventsData.filter(e => e.actors?.includes(slug!));
---

<Base title={`${actor.name} — The Orbital`} description={actor.description}>
  <div class="container">
    <div class="actor-wrap">

      <div class="actor-header-top">
        <div class="actor-title-row">
          {getLogo(actor.website) && (
            <img
              src={getLogo(actor.website)}
              alt={`${actor.name} logo`}
              class="actor-logo"
              referrerpolicy="no-referrer"
              onerror="this.style.display='none'"
            />
          )}
          <div>
            <p class="actor-eyebrow">{actor.type || 'Actor'}{actor.scale ? ` · ${actor.scale}` : ''}</p>
            <h1 class="actor-title">{actor.name}</h1>
          </div>
        </div>
        <div class="actor-orient-row">
          {actor.orientations.map(o => (
            <span class="orient-chip">
              <img src={`/assets/${iconMap[o]}`} alt="" class="orient-icon" />
              {orientationLabels[o]}
            </span>
          ))}
        </div>
      </div>

      <p class="actor-desc">{(actor as any).about || actor.description}</p>

      <div class="actor-meta">
        {actor.website && <a href={actor.website} target="_blank" rel="noopener" class="website-link">Visit website ↗</a>}
        {actor.location && <span class="actor-loc">{actor.location}</span>}
      </div>

      {((actor as any).founded || (actor as any).lastActive || (actor as any).fundingDisclosure) && (
        <div class="credibility-row">
          {(actor as any).founded && (
            <div class="cred-item">
              <span class="cred-label">Founded</span>
              <span class="cred-value">{(actor as any).founded}</span>
            </div>
          )}
          {(actor as any).lastActive && (
            <div class="cred-item">
              <span class="cred-label">Active</span>
              <span class="cred-value">{(actor as any).lastActive}</span>
            </div>
          )}
          {(actor as any).fundingDisclosure && (
            <div class="cred-item cred-item--wide">
              <span class="cred-label">Funding</span>
              <span class="cred-value">{(actor as any).fundingDisclosure}</span>
            </div>
          )}
        </div>
      )}

      {actor.tags?.length > 0 && (
        <div class="tags tags-row">
          {actor.tags.map((tag: string) => <a href={`/tags/${tag}`} class="tag">{tag.replace(/-/g, '\u00a0')}</a>)}
        </div>
      )}

      {relatedNews.length > 0 && (
        <section>
          <h2 class="section-heading">News <span class="count">({relatedNews.length})</span></h2>
          {relatedNews.map(s => (
            <article class="item">
              <time class="item-date">{formatDate(s.date)}</time>
              <h3 class="item-title"><a href={`/news/${s.slug}`}>{s.title}</a></h3>
              <p class="item-desc">{s.summary}</p>
            </article>
          ))}
        </section>
      )}

      {relatedProjects.length > 0 && (
        <section>
          <h2 class="section-heading">Projects <span class="count">({relatedProjects.length})</span></h2>
          {relatedProjects.map(p => (
            <article class="item">
              <h3 class="item-title"><a href={`/projects/${p.slug}`}>{p.name}</a></h3>
              <p class="item-desc">{p.description}</p>
            </article>
          ))}
        </section>
      )}

      {relatedEvents.length > 0 && (
        <section>
          <h2 class="section-heading">Events <span class="count">({relatedEvents.length})</span></h2>
          {relatedEvents.map(e => (
            <article class="item">
              {e.date_start && <time class="item-date">{formatDate(e.date_start)}{e.location ? ` · ${e.location}` : ''}</time>}
              <h3 class="item-title"><a href={e.website} target="_blank" rel="noopener">{e.name}</a></h3>
              <p class="item-desc">{e.description}</p>
            </article>
          ))}
        </section>
      )}

      <a href="/actors" class="back-link">← All actors</a>
    </div>
  </div>
</Base>

<style>
.actor-wrap { max-width: var(--max-w); margin: 0 auto; padding-top: 2rem; }

.actor-header-top { padding-bottom: 1.25rem; border-bottom: 3px double var(--border); margin-bottom: 1.25rem; }
.actor-title-row { display: flex; align-items: center; gap: 1rem; margin-bottom: .75rem; }
.actor-logo {
  width: 48px;
  height: 48px;
  object-fit: contain;
  border-radius: 8px;
  flex-shrink: 0;
  border: 1px solid var(--border);
  padding: 4px;
  background: #fff;
}
.actor-eyebrow { font-family: var(--font-sans); font-size: .6875rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--text-3); margin-bottom: .3rem; }
.actor-title { font-family: 'Playfair Display', Georgia, serif; font-size: 2rem; font-weight: 400; line-height: 1.2; margin-bottom: 0; }
.actor-orient-row { display: flex; flex-wrap: wrap; gap: .4rem; }

.orient-chip {
  display: inline-flex;
  align-items: center;
  gap: .3rem;
  font-size: .75rem;
  color: var(--text-2);
  background: var(--filter-bg);
  padding: .2rem .6rem .2rem .4rem;
  border-radius: 999px;
}
.orient-icon { width: 16px; height: 16px; object-fit: contain; }

.actor-desc { font-family: 'Source Serif 4', Georgia, serif; font-size: 1.0625rem; line-height: 1.75; color: #333; margin-bottom: 1rem; font-weight: 300; }

.actor-meta { display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; font-size: .875rem; margin-bottom: 1rem; }
.website-link { color: var(--text); font-weight: 600; text-decoration: none; }
.website-link:hover { text-decoration: underline; }
.actor-loc { color: var(--text-3); font-size: .8125rem; }

.tags-row { margin-bottom: 1.5rem; }

.credibility-row {
  display: flex;
  flex-wrap: wrap;
  gap: .5rem 1.5rem;
  margin-bottom: 1.25rem;
  padding: .75rem 1rem;
  background: var(--filter-bg);
  border-radius: 6px;
  border: 1px solid var(--border);
}
.cred-item {
  display: flex;
  flex-direction: column;
  gap: .15rem;
}
.cred-item--wide { flex: 1; min-width: 180px; }
.cred-label {
  font-family: var(--font-sans);
  font-size: .625rem;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--text-3);
}
.cred-value {
  font-size: .875rem;
  color: var(--text-2);
}

.section-heading {
  font-family: var(--font-sans);
  font-size: .6875rem;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--text-3);
  margin: 2rem 0 1rem;
  padding-bottom: .5rem;
  border-bottom: 1px solid var(--border);
}
.section-heading .count { color: var(--text-3); font-weight: 400; margin-left: .25rem; }

.item { padding: .875rem 0; border-bottom: 1px solid var(--border); }
.item-date { display: block; font-size: .75rem; color: var(--text-3); margin-bottom: .25rem; }
.item-title { font-family: 'Source Serif 4', Georgia, serif; font-size: 1.0625rem; font-weight: 400; line-height: 1.35; margin-bottom: .25rem; }
.item-title a { text-decoration: none; }
.item-title a:hover { text-decoration: underline; }
.item-desc { font-size: .875rem; color: var(--text-2); line-height: 1.55; }

.back-link { display: inline-block; margin-top: 2rem; font-size: .875rem; color: var(--text-2); text-decoration: none; }
.back-link:hover { color: var(--text); }
</style>
