---
import Base from '../../layouts/Base.astro';
---

<Base title="Signing in… — The Orbital" description="">
  <div class="container">
    <div class="callback-wrap">
      <p class="callback-msg" id="callback-msg">Signing you in…</p>
      <pre id="debug-out" class="debug-out" style="display:none"></pre>
    </div>
  </div>
</Base>

<script>
  import { createClient } from '@supabase/supabase-js';

  const SUPABASE_URL = 'https://lathlnothoosbwrvxtel.supabase.co';
  const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxhdGhsbm90aG9vc2J3cnZ4dGVsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzczNjU1OTYsImV4cCI6MjA5Mjk0MTU5Nn0.VZJxCAbOfpiepbvgq9m0xC2wMe0IgFNlUUUC9wbk3Gc';

  const debugLog: string[] = [];
  function log(...args: any[]) {
    const line = '[callback] ' + args.map(a =>
      typeof a === 'object' ? JSON.stringify(a, null, 2) : String(a)
    ).join(' ');
    console.log(line);
    debugLog.push(line);
  }

  // Disable auto-detect so we control the exchange explicitly
  const supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
    auth: {
      persistSession: true,
      autoRefreshToken: true,
      detectSessionInUrl: false,
      flowType: 'pkce',
    },
  });
  (window as any).__supabase = supabase;

  const msgEl = document.getElementById('callback-msg');
  const debugEl = document.getElementById('debug-out');
  function setMsg(s: string) { if (msgEl) msgEl.textContent = s; }
  function showDebug() {
    if (debugEl) {
      debugEl.textContent = debugLog.join('\n');
      debugEl.style.display = 'block';
    }
  }

  let handled = false;

  function bail(reason: string, redirect: boolean = true) {
    if (handled) return;
    handled = true;
    log('BAIL:', reason);
    setMsg('Sign-in failed. Redirecting in 4s…');
    showDebug();
    if (redirect) {
      setTimeout(() => { window.location.href = '/login?error=auth_failed'; }, 4000);
    }
  }

  log('URL:', window.location.href);
  log('search:', window.location.search);
  log('hash:', window.location.hash);

  const params = new URLSearchParams(window.location.search);
  const code = params.get('code');
  const errParam = params.get('error');
  const errDesc = params.get('error_description');

  if (errParam) {
    bail(`OAuth provider error: ${errParam} — ${errDesc ?? 'no description'}`);
  } else if (!code) {
    bail('No ?code= param in callback URL');
  } else {
    log('exchanging code...');
    setMsg('Verifying your sign-in…');

    supabase.auth.exchangeCodeForSession(code)
      .then(async ({ data, error }) => {
        if (error) {
          bail('exchangeCodeForSession error: ' + error.message);
          return;
        }
        if (!data?.session) {
          bail('exchange returned no session');
          return;
        }

        log('exchange OK, user:', data.session.user.email);
        await processSession(data.session);
      })
      .catch((e) => {
        bail('exchange threw: ' + (e?.message ?? String(e)));
      });
  }

  async function processSession(session: any) {
    if (handled) return;
    const user = session.user;
    const email = (user.email ?? '').toLowerCase();

    setMsg('Verifying your invitation…');
    log('checking invite for', email);

    try {
      const { data: invite, error: inviteErr } = await supabase
        .from('invites')
        .select('id, used_at')
        .eq('email', email)
        .maybeSingle();

      if (inviteErr) {
        log('invite query error:', inviteErr.message);
        // Don't bail — let it through if RLS/query fails, easier to debug
        // Actually, security-wise we should bail. But surface the error.
        bail('invite check failed: ' + inviteErr.message);
        return;
      }

      if (!invite) {
        log('no invite found, signing out');
        handled = true;
        setMsg('Email not on invite list. Redirecting…');
        await supabase.auth.signOut();
        setTimeout(() => { window.location.href = '/login?error=not_invited'; }, 1200);
        return;
      }

      log('invite found, used_at =', invite.used_at);

      if (!invite.used_at) {
        await supabase.from('invites')
          .update({ used_at: new Date().toISOString() })
          .eq('id', invite.id);
      }

      // Upsert profile (best-effort)
      const { error: profileErr } = await supabase.from('user_profiles').upsert(
        {
          id: user.id,
          email,
          display_name:
            user.user_metadata?.full_name ??
            user.user_metadata?.name ??
            email.split('@')[0],
          avatar_url:
            user.user_metadata?.avatar_url ??
            user.user_metadata?.picture ??
            null,
          last_sign_in: new Date().toISOString(),
        },
        { onConflict: 'id' },
      );
      if (profileErr) log('profile upsert error (non-fatal):', profileErr.message);

      handled = true;
      setMsg('Welcome. Redirecting…');
      const next = new URLSearchParams(window.location.search).get('next') ?? '/';
      window.location.href = next;
    } catch (e: any) {
      bail('processSession threw: ' + (e?.message ?? String(e)));
    }
  }

  // Hard timeout safety net
  setTimeout(() => {
    if (!handled) bail('15s timeout — nothing completed');
  }, 15000);
</script>

<style>
.callback-wrap {
  max-width: 600px;
  margin: 6rem auto;
  text-align: center;
  padding: 0 1rem;
}
.callback-msg {
  font-size: .9375rem;
  color: var(--text-2);
  font-style: italic;
}
.debug-out {
  margin-top: 2rem;
  text-align: left;
  background: #f5f5f5;
  border: 1px solid #ddd;
  border-radius: 4px;
  padding: 1rem;
  font-size: .75rem;
  font-family: monospace;
  white-space: pre-wrap;
  word-break: break-all;
  color: #444;
  max-height: 400px;
  overflow: auto;
}
</style>
