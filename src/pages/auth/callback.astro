---
import Base from '../../layouts/Base.astro';
---

<Base title="Signing in… — The Orbital" description="">
  <div class="container">
    <div class="callback-wrap">
      <p class="callback-msg" id="callback-msg">Signing you in…</p>
    </div>
  </div>
</Base>

<script>
  import { createBrowserClient } from '@supabase/ssr';

  const SUPABASE_URL = 'https://lathlnothoosbwrvxtel.supabase.co';
  const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxhdGhsbm90aG9vc2J3cnZ4dGVsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzczNjU1OTYsImV4cCI6MjA5Mjk0MTU5Nn0.VZJxCAbOfpiepbvgq9m0xC2wMe0IgFNlUUUC9wbk3Gc';

  // createBrowserClient sets detectSessionInUrl:true + flowType:'pkce' by default.
  // It automatically exchanges the ?code= param — we must NOT call
  // exchangeCodeForSession() manually or we'll double-consume the code and hang.
  const supabase = createBrowserClient(SUPABASE_URL, SUPABASE_ANON_KEY);

  const msgEl = document.getElementById('callback-msg');
  function setMsg(s: string) { if (msgEl) msgEl.textContent = s; }

  let handled = false;

  function bail(reason: string) {
    if (handled) return;
    handled = true;
    setMsg('Sign-in failed. Redirecting…');
    console.error('[auth/callback] bail:', reason);
    setTimeout(() => { window.location.href = '/login?error=auth_failed'; }, 1500);
  }

  // Wait for the client to finish the auto-exchange and emit SIGNED_IN
  const { data: { subscription } } = supabase.auth.onAuthStateChange(
    async (event, session) => {
      if (handled) return;

      if (event === 'SIGNED_IN' && session) {
        handled = true;
        subscription.unsubscribe();

        const user = session.user;
        const email = (user.email ?? '').toLowerCase();

        // ── Invite check ────────────────────────────────────────────────────
        // RLS allows authenticated users to SELECT their own invite row only.
        const { data: invite } = await supabase
          .from('invites')
          .select('id, used_at')
          .eq('email', email)
          .maybeSingle();

        if (!invite) {
          await supabase.auth.signOut();
          window.location.href = '/login?error=not_invited';
          return;
        }

        // Mark invite used (idempotent)
        if (!invite.used_at) {
          await supabase
            .from('invites')
            .update({ used_at: new Date().toISOString() })
            .eq('id', invite.id);
        }

        // ── Upsert profile ───────────────────────────────────────────────────
        await supabase.from('user_profiles').upsert(
          {
            id: user.id,
            email,
            display_name:
              user.user_metadata?.full_name ??
              user.user_metadata?.name ??
              email.split('@')[0],
            avatar_url:
              user.user_metadata?.avatar_url ??
              user.user_metadata?.picture ??
              null,
            last_sign_in: new Date().toISOString(),
          },
          { onConflict: 'id' },
        );

        const next = new URLSearchParams(window.location.search).get('next') ?? '/';
        window.location.href = next;

      } else if (event === 'INITIAL_SESSION' && !session) {
        // Auto-exchange failed or no code in URL — bail after a short grace period
        // (give SIGNED_IN a moment to arrive before giving up)
        setTimeout(() => bail('INITIAL_SESSION with no session'), 3000);
      }
    }
  );

  // Hard timeout — if nothing happens in 12 seconds, something is very wrong
  setTimeout(() => bail('timeout waiting for SIGNED_IN'), 12000);
</script>

<style>
.callback-wrap {
  max-width: 420px;
  margin: 8rem auto;
  text-align: center;
  padding: 0 1rem;
}
.callback-msg {
  font-size: .9375rem;
  color: var(--text-2);
  font-style: italic;
}
</style>
