  color: #c4910a;
  border: 1px solid rgba(196,145,10,.45);
  padding: .22rem .6rem;
  border-radius: 3px;
  transition: border-color .2s, color .2s;
}
.dispatch-issue {
  font-family: var(--font-sans);
  font-size: .8125rem;
  color: rgba(255,255,255,.5);
  letter-spacing: .04em;
}

/* Digest card body */
.digest-meta-row {
  display: flex;
  align-items: center;
