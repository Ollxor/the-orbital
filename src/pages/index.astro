---
import Base from '../layouts/Base.astro';
import newsData from '../data/news.json';
import actorsData from '../data/actors.json';
import projectsData from '../data/projects.json';
import eventsData from '../data/events.json';

// Homepage shows main-tier only. Stream-tier entries appear at /stream.
// Entries without an explicit tier are treated as main (legacy compat).
const news = [...newsData]
  .filter(n => !(n as any).tier || (n as any).tier === 'main')
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const actorCount = actorsData.length;
const projectCount = projectsData.length;
const eventCount = eventsData.length;

// Group news by YYYY-MM for month headings
function monthKey(dateStr: string) {
  return dateStr.slice(0, 7);
}
function monthLabel(key: string) {
  const [y, m] = key.split('-');
  const d = new Date(Number(y), Number(m) - 1, 1);
  return d.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
}
const groupedNews: { key: string; label: string; stories: typeof news }[] = [];
for (const story of news) {
  const key = monthKey(story.date);
  const last = groupedNews[groupedNews.length - 1];
  if (last && last.key === key) last.stories.push(story);
  else groupedNews.push({ key, label: monthLabel(key), stories: [story] });
}

const orientationLabels: Record<string, string> = {
  GARDEN: 'The Garden',
  SPACESHIP: 'Spaceship Earth',
  MYSTERIES: 'The Mysteries',
  ASSEMBLY: 'The Assemblies',
};

const iconMap: Record<string, string> = {
  GARDEN: 'Icons2-01.svg',
  SPACESHIP: 'Icons2-04.svg',
  MYSTERIES: 'Icons2-03.svg',
  ASSEMBLY: 'Icons2-02.svg',
};

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}

function truncate(text: string, max: number) {
  if (!text) return '';
  if (text.length <= max) return text;
  const slice = text.slice(0, max);
  const lastSpace = slice.lastIndexOf(' ');
  return (lastSpace > max * 0.6 ? slice.slice(0, lastSpace) : slice) + '…';
}

const actorMap = Object.fromEntries(actorsData.map(a => [a.slug, a]));
const newsMap   = Object.fromEntries(newsData.map(s => [s.slug, s]));
const orientations = ['GARDEN','SPACESHIP','MYSTERIES','ASSEMBLY'] as const;
---

<Base>
  <div class="container">

    <div class="filter-bar" id="filter-bar">
      {orientations.map(key => (
        <button class="filter-btn active" data-orientation={key} aria-pressed="true">
          <img src={`/assets/${iconMap[key]}`} alt={orientationLabels[key]} class="filter-icon" />
          <span class="filter-label">{orientationLabels[key]}</span>
        </button>
      ))}
    </div>

    <p class="stats-bar">
      <span>{actorCount} actors</span>
      <span class="sep">&middot;</span>
      <span>{projectCount} projects</span>
      <span class="sep">&middot;</span>
      <span>{eventCount} events</span>
    </p>

    <section class="feed">
      <h2 class="feed-heading">From the Field</h2>

      {groupedNews.map(group => (
        <>
        <h3 class="feed-month" id={`m-${group.key}`}>{group.label} <span class="month-count">({group.stories.length})</span></h3>
        {group.stories.map((story) => (
          (story as any).kind === 'digest' ? (

            /* ── Weekly Orbital Dispatch card ── */
            <article class="news-card digest-card" data-orientations={story.orientations.join(',')}>
              <a href={`/news/${story.slug}`} class="digest-hero-link" aria-label={`Read ${story.title}`}>
                <div class="digest-hero">
                  <div class="digest-stars" aria-hidden="true"></div>
                  <div class="orbit-container" aria-hidden="true">
                    <div class="orbit-ring orbit-ring-3"></div>
                    <div class="orbit-ring orbit-ring-2"></div>
                    <div class="orbit-ring orbit-ring-1"></div>
                    <div class="orbit-center"></div>
                    <div class="orbit-arm orbit-arm-a"><div class="orbit-dot orbit-dot-a"></div></div>
                    <div class="orbit-arm orbit-arm-b"><div class="orbit-dot orbit-dot-b"></div></div>
                    <div class="orbit-arm orbit-arm-c"><div class="orbit-dot orbit-dot-c"></div></div>
                  </div>
                  <div class="digest-hero-footer">
                    <span class="dispatch-badge">Orbital Dispatch</span>
                    <span class="dispatch-issue">#{(story as any).issueNumber || '—'}</span>
                  </div>
                </div>
              </a>
              <div class="card-body">
                <div class="digest-meta-row">
                  <time class="card-date">{formatDate(story.date)}</time>
                  {(story as any).storyCount && (
                    <span class="digest-count">{(story as any).storyCount} stories this week</span>
                  )}
                </div>
                <h3 class="card-title">
                  <a href={`/news/${story.slug}`}>{story.title}</a>
                </h3>
                <p class="card-summary">{truncate(story.summary, 160)}</p>
                {((story as any).highlightedSlugs || []).length > 0 && (
                  <ul class="digest-bullets">
                    {((story as any).highlightedSlugs as string[]).slice(0, 5).map((s: string) =>
                      newsMap[s] && (
                        <li class="digest-bullet">
                          <a href={`/news/${s}`}>{(newsMap[s] as any).title}</a>
                        </li>
                      )
                    )}
                  </ul>
                )}
                <a href={`/news/${story.slug}`} class="card-readmore dispatch-readmore">Read the full dispatch →</a>
              </div>
            </article>

          ) : (

            /* ── Standard news / video card ── */
            <article
              class="news-card"
              data-slug={story.slug}
              data-title={story.title}
              data-date={story.date}
              data-orientations={story.orientations.join(',')}
              data-tags={(story.tags || []).join(',')}
              data-source-url={story.sourceUrl || ''}
              data-tier={(story as any).tier || 'main'}
              data-kind={(story as any).kind || 'article'}
            >
              <div class={`card-image-wrap${story.image ? '' : ' card-placeholder'}${(story as any).kind === 'video' ? ' card-video' : ''}`} data-orient={story.orientations[0] || 'GARDEN'}>
                <a href={`/news/${story.slug}`}>
                  {story.image ? (
                    <img src={story.image} alt={story.imageAlt} class="card-image" loading="lazy" referrerpolicy="no-referrer" onerror="this.parentElement.parentElement.classList.add('card-placeholder'); this.remove();" />
                  ) : (
                    <img src={`/assets/${iconMap[story.orientations[0] || 'GARDEN']}`} alt="" class="placeholder-icon" />
                  )}
                  {(story as any).kind === 'video' && (
                    <div class="video-play-overlay" aria-hidden="true">
                      <span class="video-play-btn">&#9654;</span>
                      <span class="video-badge">Video</span>
                    </div>
                  )}
                </a>
              </div>
              <div class="card-body">
                <time class="card-date">{formatDate(story.date)}</time>
                <h3 class="card-title">
                  <a href={`/news/${story.slug}`}>{story.title}</a>
                </h3>
                <p class="card-summary">{truncate(story.summary, 140)}</p>
                {story.insight && (
                  <p class="card-insight">
                    <span class="insight-label">Why this matters →</span>
                    {truncate(story.insight, 120)}
                  </p>
                )}
                <a href={`/news/${story.slug}`} class="card-readmore">Continue reading →</a>
                <div class="card-meta">
                  {story.actors.map(slug => actorMap[slug] && (
                    <a href={`/actors/${slug}`} class="card-actor">{actorMap[slug].name}</a>
                  ))}
                  <div class="tags">
                    {story.tags.map(tag => (
                      <a href={`/tags/${tag}`} class="tag">{tag.replace(/-/g, ' ')}</a>
                    ))}
                  </div>
                </div>
                <div class="card-reactions" data-story={story.slug}>
                  {orientations.map(key => (
                    <button class="reaction-btn" data-orientation={key} aria-label={`Tag as ${orientationLabels[key]}`}>
                      <img src={`/assets/${iconMap[key]}`} alt="" class="reaction-icon" />
                      <span class="reaction-count"></span>
                    </button>
                  ))}
                </div>
              </div>
            </article>

          )
        ))}
        </>
      ))}
    </section>

    <aside class="stream-callout admin-only" style="display:none">
      <div class="stream-callout-inner">
        <p class="stream-callout-eyebrow">Looking for more</p>
        <h2 class="stream-callout-title">The Stream</h2>
        <p class="stream-callout-body">
          The wider feed of context, commentary, and smaller-scope practice notes
          that didn't make the highlight reel — but still cleared our planetary
          governance filter.
        </p>
        <a href="/stream" class="stream-callout-link">Open the stream →</a>
      </div>
    </aside>

  </div>
</Base>

<style>
.filter-bar {
  margin-top: 1.75rem;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  gap: 2rem;
  padding: 1rem 1.25rem;
  background: var(--filter-bg);
  border-radius: 8px;
  margin-bottom: .875rem;
}
.filter-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .35rem;
  background: none;
  border: none;
  cursor: pointer;
  padding: .25rem .5rem;
  opacity: 1;
  border-radius: 6px;
  transition: transform .15s, opacity .15s, background .15s;
}
.filter-btn:hover { transform: scale(1.06); }
.filter-btn:not(.active) { opacity: .22; filter: grayscale(1); }
.filter-icon { width: 36px; height: 36px; object-fit: contain; }
.filter-label { font-size: .625rem; color: var(--text-3); text-align: center; white-space: nowrap; letter-spacing: .04em; text-transform: uppercase; }

.stats-bar {
  font-size: .75rem;
  color: var(--text-3);
  margin-bottom: 2rem;
  display: flex;
  gap: .5rem;
  align-items: center;
  justify-content: center;
}
.sep { color: var(--border); }

.feed-heading {
  font-family: var(--font-sans);
  font-size: .625rem;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--text-3);
  margin-bottom: 1.75rem;
  text-align: center;
}
.feed-month {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 1rem;
  font-weight: 400;
  color: var(--text-3);
  margin: 2rem 0 1.5rem;
  padding-bottom: .375rem;
  border-bottom: 1px solid var(--border);
  letter-spacing: .02em;
}
.feed-month:first-of-type { margin-top: .75rem; }
.month-count { font-size: .6875rem; color: var(--text-3); font-family: var(--font-sans); margin-left: .3rem; opacity: .7; }

.news-card {
  border-bottom: 1px solid var(--border);
  padding-bottom: 2.25rem;
  margin-bottom: 2.25rem;
  transition: opacity .2s;
}
.news-card.hidden { opacity: .2; pointer-events: none; }

/* ── Read state (global selectors so dynamically-injected elements style) ── */
:global(.news-card.is-read) { opacity: .55; }
:global(.news-card.is-read:hover) { opacity: .85; }
:global(.news-card.is-read .card-image-wrap) { filter: saturate(.55); }

:global(.read-row) {
  display: flex;
  align-items: center;
  gap: .625rem;
  margin-top: .875rem;
  padding-top: .75rem;
  border-top: 1px dashed var(--border);
}
:global(.mark-read-btn) {
  position: relative;
  font-family: var(--font-sans);
  font-size: .6875rem;
  font-weight: 600;
  letter-spacing: .07em;
  text-transform: uppercase;
  padding: .45rem .9rem;
  background:
    radial-gradient(ellipse 70% 60% at 30% 30%, rgba(255,255,255,.6), transparent 70%),
    radial-gradient(ellipse 60% 80% at 80% 70%, rgba(74,124,89,.05), transparent 60%),
    var(--bg);
  color: var(--text-2);
  border: 1px solid var(--border);
  border-radius: 999px;
  cursor: pointer;
  transition: transform .15s, border-color .2s, color .2s, box-shadow .25s;
  white-space: nowrap;
  box-shadow: inset 0 1px 0 rgba(255,255,255,.5), 0 1px 2px rgba(0,0,0,.04);
}
:global(.mark-read-btn:hover) {
  border-color: #4a7c59;
  color: #4a7c59;
  transform: translateY(-1px);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.5), 0 3px 10px rgba(74,124,89,.18);
}
:global(.mark-read-btn[data-read="1"]) {
  background:
    radial-gradient(ellipse 70% 60% at 30% 30%, rgba(255,255,255,.18), transparent 60%),
    radial-gradient(ellipse 80% 80% at 70% 70%, rgba(0,0,0,.18), transparent 60%),
    linear-gradient(135deg, #5d9573 0%, #3e6b4a 100%);
  color: #fff;
  border-color: #3e6b4a;
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,.25),
    0 0 0 3px rgba(74,124,89,.12),
    0 2px 6px rgba(74,124,89,.3);
}
:global(.mark-read-btn[data-read="1"]:hover) {
  background:
    radial-gradient(ellipse 70% 60% at 30% 30%, rgba(255,255,255,.18), transparent 60%),
    radial-gradient(ellipse 80% 80% at 70% 70%, rgba(0,0,0,.18), transparent 60%),
    linear-gradient(135deg, #6ba180 0%, #487856 100%);
  color: #fff;
  transform: translateY(-1px);
}

/* ── Standard card image ── */
.card-image-wrap { margin-bottom: 1rem; position: relative; border-radius: 5px; overflow: hidden; }
.card-image { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; }

.card-placeholder {
  aspect-ratio: 16/9;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}
.card-placeholder a { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; position: relative; z-index: 2; }

/* Painterly splotch overlay — Hades-inspired ink blots */
.card-placeholder::before {
  content: '';
  position: absolute; inset: -10%;
  background:
    radial-gradient(ellipse 30% 25% at 18% 28%, rgba(255,255,255,.55), transparent 70%),
    radial-gradient(ellipse 22% 35% at 78% 22%, rgba(0,0,0,.18), transparent 65%),
    radial-gradient(ellipse 35% 28% at 42% 78%, rgba(0,0,0,.12), transparent 60%),
    radial-gradient(ellipse 18% 22% at 88% 72%, rgba(255,255,255,.4), transparent 70%);
  filter: blur(1px);
  z-index: 0;
}
/* Grain/texture overlay */
.card-placeholder::after {
  content: '';
  position: absolute; inset: 0;
  background-image:
    radial-gradient(1.5px 1.5px at 12% 18%, rgba(0,0,0,.12), transparent),
    radial-gradient(1.5px 1.5px at 28% 42%, rgba(0,0,0,.08), transparent),
    radial-gradient(2px 2px at 56% 16%, rgba(255,255,255,.4), transparent),
    radial-gradient(1.5px 1.5px at 72% 64%, rgba(0,0,0,.1), transparent),
    radial-gradient(2px 2px at 84% 32%, rgba(255,255,255,.35), transparent),
    radial-gradient(1.5px 1.5px at 38% 84%, rgba(0,0,0,.08), transparent);
  mix-blend-mode: overlay;
  pointer-events: none;
  z-index: 1;
}

.card-placeholder[data-orient="GARDEN"] {
  background:
    radial-gradient(ellipse 65% 55% at 30% 40%, #b9d3c0, transparent 70%),
    radial-gradient(ellipse 55% 60% at 75% 65%, #87ad94, transparent 70%),
    radial-gradient(ellipse 40% 50% at 50% 90%, #6b8f78, transparent 75%),
    linear-gradient(135deg, #d8e6dc 0%, #93b39c 100%);
}
.card-placeholder[data-orient="SPACESHIP"] {
  background:
    radial-gradient(ellipse 65% 55% at 25% 35%, #b9cfdf, transparent 70%),
    radial-gradient(ellipse 55% 60% at 75% 70%, #6f8aa6, transparent 70%),
    radial-gradient(ellipse 40% 50% at 60% 18%, #4d7090, transparent 75%),
    linear-gradient(135deg, #d4e1ed 0%, #7090b0 100%);
}
.card-placeholder[data-orient="MYSTERIES"] {
  background:
    radial-gradient(ellipse 65% 55% at 28% 30%, #c8b4dc, transparent 70%),
    radial-gradient(ellipse 55% 60% at 78% 70%, #826099, transparent 70%),
    radial-gradient(ellipse 40% 50% at 55% 92%, #5d4080, transparent 75%),
    linear-gradient(135deg, #ddccea 0%, #8568a4 100%);
}
.card-placeholder[data-orient="ASSEMBLY"] {
  background:
    radial-gradient(ellipse 65% 55% at 22% 38%, #ead7b1, transparent 70%),
    radial-gradient(ellipse 55% 60% at 78% 65%, #c19c5e, transparent 70%),
    radial-gradient(ellipse 40% 50% at 55% 12%, #a07a3d, transparent 75%),
    linear-gradient(135deg, #efe1c2 0%, #b89060 100%);
}

.placeholder-icon {
  width: 72px; height: 72px;
  object-fit: contain;
  position: relative; z-index: 2;
  filter:
    drop-shadow(0 2px 6px rgba(0,0,0,.35))
    drop-shadow(0 0 20px rgba(255,255,255,.3));
  opacity: .92;
  transition: transform .3s, filter .3s;
}
.card-placeholder:hover .placeholder-icon {
  transform: scale(1.06) rotate(-2deg);
  filter:
    drop-shadow(0 3px 10px rgba(0,0,0,.4))
    drop-shadow(0 0 28px rgba(255,255,255,.5));
}

.card-video { position: relative; }
.video-play-overlay {
  position: absolute; inset: 0;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: .5rem; background: rgba(0,0,0,.2); transition: background .2s;
}
.card-image-wrap:hover .video-play-overlay { background: rgba(0,0,0,.35); }
.video-play-btn {
  width: 52px; height: 52px;
  background: rgba(255,255,255,.92); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.375rem; color: #1a1a1a; padding-left: 3px;
  box-shadow: 0 2px 12px rgba(0,0,0,.25);
}
.video-badge {
  font-size: .625rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
  color: #fff; background: rgba(0,0,0,.5); padding: .15rem .55rem; border-radius: 999px;
}

/* ── Card body shared ── */
.card-date { display: block; font-size: .75rem; color: var(--text-3); margin-bottom: .375rem; letter-spacing: .02em; }
.card-title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 1.3125rem; font-weight: 400; line-height: 1.3; margin-bottom: .625rem;
}
.card-title a { text-decoration: none; color: var(--text); }
.card-title a:hover { text-decoration: underline; }
.card-summary { font-size: .9375rem; color: #444; line-height: 1.65; margin-bottom: .75rem; }
.card-insight { font-size: .875rem; color: var(--text-3); font-style: italic; line-height: 1.55; margin-bottom: .875rem; }
.insight-label { font-style: normal; font-weight: 600; color: var(--text-3); margin-right: .375rem; font-size: .8125rem; }
.card-readmore { display: inline-block; font-size: .8125rem; font-weight: 600; color: var(--text-2); text-decoration: none; margin-bottom: .875rem; letter-spacing: .02em; }
.card-readmore:hover { color: var(--text); text-decoration: none; }
.card-meta { display: flex; flex-wrap: wrap; align-items: center; gap: .5rem; margin-bottom: .875rem; }
.card-actor { font-size: .8125rem; font-weight: 500; color: var(--text-2); text-decoration: none; }
.card-actor:hover { color: var(--text); }
.card-reactions {
  display: flex;
  gap: 1.1rem;
  padding-top: .875rem;
  border-top: 1px solid var(--border);
}
.reaction-btn {
  position: relative;
  display: flex;
  align-items: center;
  gap: .35rem;
  background: none;
  border: none;
  cursor: pointer;
  padding: .25rem .35rem;
  opacity: .55;
  transition: opacity .2s, transform .2s;
  z-index: 1;
}
/* Splotchy ink halo behind each icon */
.reaction-btn::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 32px;
  height: 32px;
  transform: translate(-50%, -50%) scale(.4);
  background:
    radial-gradient(ellipse 60% 50% at 35% 40%, rgba(74,124,89,.55), transparent 60%),
    radial-gradient(ellipse 50% 60% at 70% 65%, rgba(74,124,89,.35), transparent 65%);
  border-radius: 50%;
  opacity: 0;
  z-index: -1;
  filter: blur(2px);
  transition: opacity .25s, transform .25s;
}
.reaction-btn[data-orientation="SPACESHIP"]::before {
  background:
    radial-gradient(ellipse 60% 50% at 35% 40%, rgba(42,100,150,.55), transparent 60%),
    radial-gradient(ellipse 50% 60% at 70% 65%, rgba(42,100,150,.35), transparent 65%);
}
.reaction-btn[data-orientation="MYSTERIES"]::before {
  background:
    radial-gradient(ellipse 60% 50% at 35% 40%, rgba(123,94,167,.55), transparent 60%),
    radial-gradient(ellipse 50% 60% at 70% 65%, rgba(123,94,167,.35), transparent 65%);
}
.reaction-btn[data-orientation="ASSEMBLY"]::before {
  background:
    radial-gradient(ellipse 60% 50% at 35% 40%, rgba(184,134,11,.55), transparent 60%),
    radial-gradient(ellipse 50% 60% at 70% 65%, rgba(184,134,11,.35), transparent 65%);
}
.reaction-btn:hover {
  opacity: .95;
  transform: translateY(-1px);
}
.reaction-btn:hover::before {
  opacity: .55;
  transform: translate(-50%, -50%) scale(1);
}
.reaction-btn.reacted {
  opacity: 1;
}
.reaction-btn.reacted::before {
  opacity: .85;
  transform: translate(-50%, -50%) scale(1.2);
}
.reaction-icon {
  width: 20px;
  height: 20px;
  object-fit: contain;
  filter: drop-shadow(0 1px 1px rgba(0,0,0,.15));
}
.reaction-count {
  font-size: .6875rem;
  font-weight: 700;
  color: var(--text-2);
  letter-spacing: .02em;
}
.reaction-count { font-size: .75rem; color: var(--text-2); min-width: 1ch; }

/* ══════════════════════════════════════
   DIGEST / ORBITAL DISPATCH CARD
══════════════════════════════════════ */

.digest-card {
  border-bottom: 1px solid var(--border);
  padding-bottom: 2.25rem;
  margin-bottom: 2.25rem;
  position: relative;
}
/* Distinctive left accent line */
.digest-card::before {
  content: '';
  position: absolute;
  left: -1.25rem;
  top: 0;
  bottom: 2.25rem;
  width: 2px;
  background: linear-gradient(to bottom, #c4910a 0%, transparent 100%);
  opacity: .5;
}

/* Hero area — dark cosmos with orbital animation */
.digest-hero-link { display: block; text-decoration: none; }
.digest-hero-link:hover .dispatch-badge { border-color: rgba(196,145,10,.9); color: #e0a820; }

.digest-hero {
  aspect-ratio: 16/9;
  background: radial-gradient(ellipse at 38% 42%, #1b1636 0%, #0c1018 55%, #091510 100%);
  border-radius: 5px;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1rem;
  cursor: pointer;
}

/* Scattered star field via background-image */
.digest-stars {
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(circle 1px at 12% 18%, rgba(255,255,255,.75) 0%, transparent 1px),
    radial-gradient(circle 1.5px at 80% 12%, rgba(255,255,255,.55) 0%, transparent 1.5px),
    radial-gradient(circle 1px at 47% 72%, rgba(255,255,255,.65) 0%, transparent 1px),
    radial-gradient(circle 1px at 88% 58%, rgba(255,255,255,.4) 0%, transparent 1px),
    radial-gradient(circle 1.5px at 22% 83%, rgba(255,255,255,.5) 0%, transparent 1.5px),
    radial-gradient(circle 1px at 63% 32%, rgba(255,255,255,.6) 0%, transparent 1px),
    radial-gradient(circle 1px at 92% 38%, rgba(255,255,255,.35) 0%, transparent 1px),
    radial-gradient(circle 1px at 33% 52%, rgba(255,255,255,.45) 0%, transparent 1px),
    radial-gradient(circle 1px at 55% 88%, rgba(255,255,255,.3) 0%, transparent 1px),
    radial-gradient(circle 1.5px at 6% 60%, rgba(255,255,255,.4) 0%, transparent 1.5px),
    radial-gradient(circle 1px at 74% 78%, rgba(255,255,255,.35) 0%, transparent 1px),
    radial-gradient(circle 1px at 18% 42%, rgba(255,255,255,.25) 0%, transparent 1px);
}

/* Orbital ring system — centered */
.orbit-container {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
}
.orbit-ring {
  position: absolute;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}
.orbit-ring-1 { width: 80px;  height: 80px;  border: 1px dashed rgba(255,255,255,.2); }
.orbit-ring-2 { width: 148px; height: 148px; border: 1px dashed rgba(255,255,255,.13); }
.orbit-ring-3 { width: 224px; height: 224px; border: 1px dotted rgba(255,255,255,.07); }

.orbit-center {
  position: absolute;
  width: 9px; height: 9px;
  background: rgba(255,255,255,.92);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  box-shadow: 0 0 14px 5px rgba(255,255,255,.35);
}

/* Rotating arms + orbiting dots */
.orbit-arm {
  position: absolute;
  top: 0; left: 0;
  width: 0; height: 0;
  transform-origin: 0 0;
}
.orbit-dot {
  position: absolute;
  border-radius: 50%;
}

/* Amber dot — middle ring, 18s */
.orbit-arm-a { animation: orbit-spin 18s linear infinite; }
.orbit-dot-a {
  width: 7px; height: 7px;
  background: #c4910a;
  top: -3.5px;
  left: 74px;
  box-shadow: 0 0 10px 4px rgba(196,145,10,.65);
}

/* Purple dot — inner ring, 28s reverse */
.orbit-arm-b { animation: orbit-spin 28s linear infinite reverse; }
.orbit-dot-b {
  width: 5px; height: 5px;
  background: #9b7ec8;
  top: -2.5px;
  left: 40px;
  box-shadow: 0 0 8px 3px rgba(123,94,167,.6);
}

/* Green dot — outer ring, 42s */
.orbit-arm-c { animation: orbit-spin 42s linear infinite; }
.orbit-dot-c {
  width: 5px; height: 5px;
  background: #4a9e6b;
  top: -2.5px;
  left: 112px;
  box-shadow: 0 0 8px 3px rgba(74,126,89,.55);
}

@keyframes orbit-spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* Bottom overlay: badge + issue number */
.digest-hero-footer {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: .625rem .875rem;
  background: linear-gradient(to top, rgba(0,0,0,.72) 0%, transparent 100%);
