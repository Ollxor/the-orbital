---
import Base from '../layouts/Base.astro';
import newsData from '../data/news.json';
import actorsData from '../data/actors.json';

// Homepage shows main-tier only. Stream-tier entries appear at /stream.
const allMain = [...newsData]
  .filter(n => !(n as any).tier || (n as any).tier === 'main')
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

// Separate digest cards (always list) from regular cards (hero/grid/list)
const digestCards   = allMain.filter(s => (s as any).kind === 'digest');
const regularCards  = allMain.filter(s => (s as any).kind !== 'digest');

const heroCard   = regularCards[0];
const gridCards  = regularCards.slice(1, 3);
const listCards  = [...regularCards.slice(3), ...digestCards];

const orientationLabels: Record<string, string> = {
  GARDEN:    'The Garden',
  SPACESHIP: 'Spaceship Earth',
  MYSTERIES: 'The Mysteries',
  ASSEMBLY:  'The Assemblies',
};
const iconMap: Record<string, string> = {
  GARDEN:    'Icons2-01.svg',
  SPACESHIP: 'Icons2-04.svg',
  MYSTERIES: 'Icons2-03.svg',
  ASSEMBLY:  'Icons2-02.svg',
};
const pipClass: Record<string, string> = {
  GARDEN:    'pip-garden',
  SPACESHIP: 'pip-space',
  MYSTERIES: 'pip-mystery',
  ASSEMBLY:  'pip-assembly',
};
const orientations = ['GARDEN','SPACESHIP','MYSTERIES','ASSEMBLY'] as const;

const actorMap = Object.fromEntries(actorsData.map(a => [a.slug, a]));

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
function truncate(text: string, max: number) {
  if (!text) return '';
  if (text.length <= max) return text;
  const s = text.slice(0, max);
  const i = s.lastIndexOf(' ');
  return (i > max * 0.6 ? s.slice(0, i) : s) + '…';
}
function hostFromUrl(url: string) {
  try { return new URL(url).hostname.replace(/^www\./, ''); } catch { return ''; }
}
---

<Base>
<div class="container">

  <!-- Filter bar -->
  <div class="filter-bar" id="filter-bar">
    <span class="filter-label-text">Filter</span>
    {orientations.map(key => (
      <button class="filter-chip active" data-orientation={key} aria-pressed="true">
        {orientationLabels[key]}
      </button>
    ))}
  </div>

  <!-- ── HERO CARD ── -->
  {heroCard && (() => {
    const s = heroCard as any;
    const isVideo = s.kind === 'video';
    const host = hostFromUrl(s.sourceUrl || '');
    return (
      <article
        class="news-card card-hero"
        data-slug={s.slug}
        data-orientations={(s.orientations ?? []).join(',')}
        data-tags={(s.tags ?? []).join(',')}
        data-tier={s.tier ?? 'main'}
        data-kind={s.kind ?? 'article'}
      >
        <div class={`card-img-wrap${s.image ? '' : ' card-placeholder'}${isVideo ? ' card-video' : ''}`} data-orient={s.orientations?.[0] ?? 'GARDEN'}>
          <a href={`/news/${s.slug}`}>
            {s.image
              ? <img src={s.image} alt={s.imageAlt} class="card-img" loading="eager" referrerpolicy="no-referrer" onerror="this.closest('.card-img-wrap').classList.add('card-placeholder');this.remove()" />
              : <img src={`/assets/${iconMap[s.orientations?.[0] ?? 'GARDEN']}`} alt="" class="placeholder-icon" />
            }
            {isVideo && (
              <div class="video-play-overlay" aria-hidden="true">
                <span class="video-play-btn">&#9654;</span>
                <span class="video-badge">Video</span>
              </div>
            )}
          </a>
        </div>
        <div class="card-body">
          <div class="card-meta-row">
            <time class="card-date">{formatDate(s.date)}</time>
            {(s.orientations ?? []).map((o: string) => (
              <span class={`orient-pip ${pipClass[o] ?? ''}`}>{orientationLabels[o] ?? o}</span>
            ))}
            {host && <span class="card-source">{host}</span>}
          </div>
          <h2 class="card-title hero-title">
            <a href={`/news/${s.slug}`}>{s.title}</a>
          </h2>
          <p class="card-summary">{truncate(s.summary, 220)}</p>
          {s.insight && (
            <div class="insight-bar">
              <p class="insight-text">{s.insight}</p>
            </div>
          )}
          <div class="card-tags">
            {(s.tags ?? []).slice(0, 5).map((t: string) => (
              <a href={`/tags/${t}`} class="tag">{t.replace(/-/g, ' ')}</a>
            ))}
          </div>
        </div>
      </article>
    );
  })()}

  <!-- ── GRID (2 columns) ── -->
  {gridCards.length > 0 && (
    <div class="card-grid">
      {gridCards.map((story) => {
        const s = story as any;
        const isVideo = s.kind === 'video';
        const host = hostFromUrl(s.sourceUrl || '');
        return (
          <article
            class="news-card card-grid-item"
            data-slug={s.slug}
            data-orientations={(s.orientations ?? []).join(',')}
            data-tags={(s.tags ?? []).join(',')}
            data-tier={s.tier ?? 'main'}
            data-kind={s.kind ?? 'article'}
          >
            <div class={`card-img-wrap grid-img${s.image ? '' : ' card-placeholder'}${isVideo ? ' card-video' : ''}`} data-orient={s.orientations?.[0] ?? 'GARDEN'}>
              <a href={`/news/${s.slug}`}>
                {s.image
                  ? <img src={s.image} alt={s.imageAlt} class="card-img" loading="lazy" referrerpolicy="no-referrer" onerror="this.closest('.card-img-wrap').classList.add('card-placeholder');this.remove()" />
                  : <img src={`/assets/${iconMap[s.orientations?.[0] ?? 'GARDEN']}`} alt="" class="placeholder-icon" />
                }
                {isVideo && (
                  <div class="video-play-overlay" aria-hidden="true">
                    <span class="video-play-btn">&#9654;</span>
                    <span class="video-badge">Video</span>
                  </div>
                )}
              </a>
            </div>
            <div class="card-body grid-body">
              <div class="card-meta-row">
                <time class="card-date">{formatDate(s.date)}</time>
                {(s.orientations ?? []).slice(0, 2).map((o: string) => (
                  <span class={`orient-pip ${pipClass[o] ?? ''}`}>{orientationLabels[o] ?? o}</span>
                ))}
                {host && <span class="card-source">{host}</span>}
              </div>
              <h2 class="card-title grid-title">
                <a href={`/news/${s.slug}`}>{s.title}</a>
              </h2>
              <p class="card-summary grid-summary">{truncate(s.summary, 130)}</p>
              <div class="card-tags">
                {(s.tags ?? []).slice(0, 3).map((t: string) => (
                  <a href={`/tags/${t}`} class="tag">{t.replace(/-/g, ' ')}</a>
                ))}
              </div>
            </div>
          </article>
        );
      })}
    </div>
  )}

  <!-- Botanical divider -->
  {listCards.length > 0 && (
    <div class="botanical-divider" aria-hidden="true">
      <div class="botanical-rule"></div>
      <svg width="80" height="18" viewBox="0 0 80 18" fill="none">
        <path d="M40 9 C37 5,30 4,27 6 C24 8,25 13,28 14 C31 15,37 13,40 9Z" fill="#4c7d5a" opacity=".35"/>
        <path d="M40 9 C43 5,50 4,53 6 C56 8,55 13,52 14 C49 15,43 13,40 9Z" fill="#4c7d5a" opacity=".25"/>
        <circle cx="40" cy="9" r="2.5" fill="#a35820" opacity=".3"/>
        <line x1="0" y1="9" x2="25" y2="9" stroke="#cec4b0" stroke-width=".8"/>
        <line x1="55" y1="9" x2="80" y2="9" stroke="#cec4b0" stroke-width=".8"/>
      </svg>
      <div class="botanical-rule"></div>
    </div>
  )}

  <!-- ── LIST CARDS ── -->
  <div class="card-list-section">
    {listCards.map((story) => {
      const s = story as any;
      const isVideo   = s.kind === 'video';
      const isDigest  = s.kind === 'digest';
      const host      = hostFromUrl(s.sourceUrl || '');

      if (isDigest) return (
        /* ── Digest / Dispatch card ── */
        <article class="news-card digest-card"
          data-slug={s.slug}
          data-orientations={(s.orientations ?? []).join(',')}
          data-tags={(s.tags ?? []).join(',')}
          data-tier={s.tier ?? 'main'}
          data-kind="digest"
        >
          <a href={`/news/${s.slug}`} class="digest-hero-link" aria-label={`Read ${s.title}`}>
            <div class="digest-hero">
              <div class="digest-stars" aria-hidden="true"></div>
              <div class="orbit-container" aria-hidden="true">
                <div class="orbit-ring orbit-ring-3"></div>
                <div class="orbit-ring orbit-ring-2"></div>
                <div class="orbit-ring orbit-ring-1"></div>
                <div class="orbit-center"></div>
                <div class="orbit-arm orbit-arm-a"><div class="orbit-dot orbit-dot-a"></div></div>
                <div class="orbit-arm orbit-arm-b"><div class="orbit-dot orbit-dot-b"></div></div>
                <div class="orbit-arm orbit-arm-c"><div class="orbit-dot orbit-dot-c"></div></div>
              </div>
              <div class="digest-hero-footer">
                <span class="dispatch-badge">Orbital Dispatch</span>
                <span class="dispatch-issue">#{s.issueNumber || '—'}</span>
              </div>
            </div>
          </a>
          <div class="card-body">
            <div class="card-meta-row">
              <time class="card-date">{formatDate(s.date)}</time>
              {s.storyCount && <span class="digest-count">{s.storyCount} stories this week</span>}
            </div>
            <h2 class="card-title"><a href={`/news/${s.slug}`}>{s.title}</a></h2>
            <p class="card-summary">{truncate(s.summary, 160)}</p>
            <a href={`/news/${s.slug}`} class="card-readmore dispatch-readmore">Read the full dispatch →</a>
          </div>
        </article>
      );

      return (
        /* ── Standard list card ── */
        <article
          class="news-card card-list"
          data-slug={s.slug}
          data-orientations={(s.orientations ?? []).join(',')}
          data-tags={(s.tags ?? []).join(',')}
          data-tier={s.tier ?? 'main'}
          data-kind={s.kind ?? 'article'}
        >
          <div class="list-body">
            <div class="card-meta-row">
              <time class="card-date">{formatDate(s.date)}</time>
              {(s.orientations ?? []).slice(0, 2).map((o: string) => (
                <span class={`orient-pip ${pipClass[o] ?? ''}`}>{orientationLabels[o] ?? o}</span>
              ))}
              {host && <span class="card-source">{host}</span>}
            </div>
            <h2 class="card-title list-title">
              <a href={`/news/${s.slug}`}>{s.title}</a>
            </h2>
            <p class="card-summary list-summary">{truncate(s.summary, 140)}</p>
            {s.insight && (
              <p class="card-insight"><span class="insight-label">Why this matters →</span>{truncate(s.insight, 110)}</p>
            )}
            <div class="card-tags">
              {(s.tags ?? []).slice(0, 4).map((t: string) => (
                <a href={`/tags/${t}`} class="tag">{t.replace(/-/g, ' ')}</a>
              ))}
            </div>
          </div>
          <div class={`card-img-wrap list-img${s.image ? '' : ' card-placeholder'}${isVideo ? ' card-video' : ''}`} data-orient={s.orientations?.[0] ?? 'GARDEN'}>
            <a href={`/news/${s.slug}`}>
              {s.image
                ? <img src={s.image} alt={s.imageAlt} class="card-img" loading="lazy" referrerpolicy="no-referrer" onerror="this.closest('.card-img-wrap').classList.add('card-placeholder');this.remove()" />
                : <img src={`/assets/${iconMap[s.orientations?.[0] ?? 'GARDEN']}`} alt="" class="placeholder-icon" />
              }
              {isVideo && (
                <div class="video-play-overlay" aria-hidden="true">
                  <span class="video-play-btn">&#9654;</span>
                  <span class="video-badge">Video</span>
                </div>
              )}
            </a>
          </div>
        </article>
      );
    })}
  </div>

  <!-- Stream callout (admin only) -->
  <aside class="stream-callout admin-only" style="display:none">
    <div class="stream-callout-inner">
      <p class="stream-callout-eyebrow">Looking for more</p>
      <h2 class="stream-callout-title">The Stream</h2>
      <p class="stream-callout-body">The wider feed of context, commentary, and smaller-scope practice notes that didn't make the highlight reel — but still cleared our planetary governance filter.</p>
      <a href="/stream" class="stream-callout-link">Open the stream →</a>
    </div>
  </aside>

</div>
</Base>

<style>
/* ── Filter bar ── */
.filter-bar {
  display: flex; align-items: center; gap: .4rem; flex-wrap: wrap;
  padding: 1.1rem 0 .9rem;
  border-bottom: 1px solid var(--border-l);
  margin-bottom: 1.75rem;
}
.filter-label-text {
  font-size: .57rem; letter-spacing: .12em; text-transform: uppercase;
  color: var(--text-3); margin-right: .2rem; flex-shrink: 0;
}
.filter-chip {
  font-size: .57rem; font-weight: 500; letter-spacing: .07em; text-transform: uppercase;
  padding: .22rem .65rem; border-radius: 99px;
  border: 1px solid var(--border); color: var(--text-3);
  cursor: pointer; transition: all .18s; background: transparent;
  font-family: var(--font-sans);
}
.filter-chip:hover { border-color: var(--text-3); color: var(--text-2); }
.filter-chip.active[data-orientation="GARDEN"]   { border-color: var(--garden);     color: var(--garden);     background: var(--garden-bg); }
.filter-chip.active[data-orientation="SPACESHIP"] { border-color: var(--spaceship);  color: var(--spaceship);  background: var(--spaceship-bg); }
.filter-chip.active[data-orientation="MYSTERIES"] { border-color: var(--mysteries);  color: var(--mysteries);  background: var(--mysteries-bg); }
.filter-chip.active[data-orientation="ASSEMBLY"]  { border-color: var(--assemblies); color: var(--assemblies); background: var(--assemblies-bg); }

/* ── Shared image/placeholder base ── */
.card-img-wrap { position: relative; overflow: hidden; border-radius: 3px; }
.card-img { width: 100%; height: 100%; object-fit: cover; display: block; }
.card-placeholder {
  display: flex; align-items: center; justify-content: center;
  position: relative; overflow: hidden;
}
.card-placeholder::before {
  content: ''; position: absolute; inset: -10%;
  background:
    radial-gradient(ellipse 30% 25% at 18% 28%, rgba(255,255,255,.5), transparent 70%),
    radial-gradient(ellipse 22% 35% at 78% 22%, rgba(0,0,0,.12), transparent 65%),
    radial-gradient(ellipse 35% 28% at 42% 78%, rgba(0,0,0,.08), transparent 60%);
  filter: blur(1px); z-index: 0;
}
.placeholder-icon {
  width: 56px; height: 56px; object-fit: contain;
  position: relative; z-index: 2;
  filter: drop-shadow(0 2px 6px rgba(0,0,0,.25)) drop-shadow(0 0 16px rgba(255,255,255,.3));
  opacity: .88; transition: transform .3s, filter .3s;
}
.card-placeholder:hover .placeholder-icon { transform: scale(1.06) rotate(-2deg); }
/* Orientation palette — softened for parchment bg */
.card-placeholder[data-orient="GARDEN"]    { background: radial-gradient(ellipse 65% 55% at 30% 40%, #b5cebb, transparent 70%), radial-gradient(ellipse 55% 60% at 75% 65%, #82a48e, transparent 70%), linear-gradient(135deg, #d4e2d8 0%, #8eaa96 100%); }
.card-placeholder[data-orient="SPACESHIP"] { background: radial-gradient(ellipse 65% 55% at 25% 35%, #b2c8da, transparent 70%), radial-gradient(ellipse 55% 60% at 75% 70%, #6882a0, transparent 70%), linear-gradient(135deg, #ccddea 0%, #6888a8 100%); }
.card-placeholder[data-orient="MYSTERIES"] { background: radial-gradient(ellipse 65% 55% at 28% 30%, #c4b0d6, transparent 70%), radial-gradient(ellipse 55% 60% at 78% 70%, #7e5e94, transparent 70%), linear-gradient(135deg, #d8caE6 0%, #826696 100%); }
.card-placeholder[data-orient="ASSEMBLY"]  { background: radial-gradient(ellipse 65% 55% at 22% 38%, #e5d0aa, transparent 70%), radial-gradient(ellipse 55% 60% at 78% 65%, #bb9558, transparent 70%), linear-gradient(135deg, #eadec4 0%, #b08c58 100%); }

/* Video overlay */
.card-video { position: relative; }
.video-play-overlay {
  position: absolute; inset: 0;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: .5rem; background: rgba(0,0,0,.18); transition: background .2s;
}
.card-img-wrap:hover .video-play-overlay { background: rgba(0,0,0,.32); }
.video-play-btn {
  width: 48px; height: 48px;
  background: rgba(255,255,255,.9); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.25rem; color: #1a1a1a; padding-left: 3px;
  box-shadow: 0 2px 10px rgba(0,0,0,.2);
}
.video-badge {
  font-size: .6rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
  color: #fff; background: rgba(0,0,0,.45); padding: .14rem .5rem; border-radius: 999px;
}

/* ── Shared card meta ── */
.card-meta-row {
  display: flex; align-items: center; gap: .4rem; flex-wrap: wrap; margin-bottom: .55rem;
}
.card-date { font-size: .6rem; font-weight: 500; letter-spacing: .05em; color: var(--text-3); }
.orient-pip {
  font-size: .56rem; font-weight: 500; letter-spacing: .04em;
  padding: .1rem .42rem; border-radius: 99px; font-family: var(--font-sans);
}
.pip-garden  { color: var(--garden);     background: var(--garden-bg); }
.pip-space   { color: var(--spaceship);  background: var(--spaceship-bg); }
.pip-mystery { color: var(--mysteries);  background: var(--mysteries-bg); }
.pip-assembly{ color: var(--assemblies); background: var(--assemblies-bg); }
.card-source { font-size: .58rem; color: var(--text-3); margin-left: auto; }

.card-title a { text-decoration: none; color: inherit; transition: color .18s; }
.card-title a:hover { color: var(--forest-2); }

.card-summary { font-family: var(--font-serif); font-weight: 300; color: var(--text-2); line-height: 1.62; }
.card-tags { display: flex; flex-wrap: wrap; gap: .28rem; margin-top: .5rem; }
.tag {
  font-size: .57rem; letter-spacing: .04em;
  padding: .14rem .44rem; border-radius: 3px;
  background: rgba(27,48,32,.04); border: 1px solid var(--border-l);
  color: var(--text-3); text-decoration: none; transition: all .18s;
}
.tag:hover { color: var(--forest-2); border-color: var(--forest-3); background: var(--garden-bg); text-decoration: none; }

.insight-bar {
  border-left: 2px solid var(--sage); padding: .45rem .75rem;
  background: var(--garden-bg); border-radius: 0 3px 3px 0; margin: .5rem 0;
}
.insight-text { font-size: .75rem; font-style: italic; line-height: 1.55; color: var(--text-2); font-family: var(--font-serif); }
.card-insight { font-size: .8rem; color: var(--text-3); font-style: italic; line-height: 1.55; margin-bottom: .5rem; }
.insight-label { font-style: normal; font-weight: 600; color: var(--text-3); margin-right: .3rem; font-size: .75rem; }
.card-readmore { display: inline-block; font-size: .78rem; font-weight: 600; color: var(--text-2); text-decoration: none; margin-bottom: .75rem; }
.card-readmore:hover { color: var(--forest-2); text-decoration: none; }

/* ── Hero card ── */
.card-hero {
  border: 1px solid var(--border-l); border-radius: 4px; overflow: hidden;
  background: var(--bg-card); margin-bottom: 1.25rem;
  transition: box-shadow .25s;
}
.card-hero:hover { box-shadow: 0 4px 20px rgba(27,48,32,.08); }
.card-hero .card-img-wrap { height: 260px; border-radius: 0; }
.card-hero .card-body { padding: 1.35rem 1.5rem 1.5rem; }
.hero-title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 1.55rem; font-weight: 400; line-height: 1.32;
  color: var(--text); margin-bottom: .55rem;
}
.card-hero .card-summary { font-size: .87rem; margin-bottom: .6rem; }

/* ── Grid ── */
.card-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 1.2rem; margin-bottom: 1.5rem;
}
.card-grid-item {
  background: var(--bg-card); border: 1px solid var(--border-l); border-radius: 4px;
  overflow: hidden; display: flex; flex-direction: column;
  transition: box-shadow .25s, transform .22s;
}
.card-grid-item:hover { box-shadow: 0 4px 16px rgba(27,48,32,.07); transform: translateY(-2px); }
.card-grid-item .card-img-wrap.grid-img { height: 148px; border-radius: 0; }
.grid-body { padding: 1rem 1.1rem 1.1rem; flex: 1; display: flex; flex-direction: column; gap: .4rem; }
.grid-title {
  font-family: 'Source Serif 4', Georgia, serif;
  font-size: 1.02rem; font-weight: 400; line-height: 1.38; color: var(--text);
}
.grid-summary { font-size: .79rem; flex: 1; }

/* ── Botanical divider ── */
.botanical-divider {
  display: flex; align-items: center; gap: 1rem;
  margin: .5rem 0 1.5rem;
}
.botanical-rule { flex: 1; height: 1px; background: var(--border); }

/* ── List cards ── */
.card-list {
  display: grid; grid-template-columns: 1fr 320px;
  gap: 1.25rem; align-items: start;
  padding: 1.25rem 0; border-bottom: 1px solid var(--border-l);
  transition: background .18s;
}
.card-list:hover { background: var(--bg-card); margin: 0 -1.5rem; padding: 1.25rem 1.5rem; }
.list-body { display: flex; flex-direction: column; gap: .4rem; }
.list-title {
  font-family: 'Source Serif 4', Georgia, serif;
  font-size: 1.05rem; font-weight: 400; line-height: 1.38; color: var(--text);
}
.list-summary { font-size: .82rem; }
.card-list .card-img-wrap.list-img { height: 192px; }

/* ── Read state ── */
:global(.news-card.is-read) { opacity: .55; }
:global(.news-card.is-read:hover) { opacity: .85; }
:global(.news-card.is-read .card-img-wrap) { filter: saturate(.5); }
:global(.read-row) {
  display: flex; align-items: center; gap: .6rem;
  margin-top: .75rem; padding-top: .65rem;
  border-top: 1px dashed var(--border);
}
:global(.mark-read-btn) {
  font-family: var(--font-sans); font-size: .62rem; font-weight: 600;
  letter-spacing: .07em; text-transform: uppercase;
  padding: .38rem .8rem;
  background: var(--bg-card); color: var(--text-2);
  border: 1px solid var(--border); border-radius: 999px;
  cursor: pointer; transition: all .18s; white-space: nowrap;
  box-shadow: 0 1px 2px rgba(0,0,0,.04);
}
