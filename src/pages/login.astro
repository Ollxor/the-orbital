---
export const prerender = false;

import Base from '../layouts/Base.astro';
import { SUPABASE_URL, SUPABASE_ANON_KEY } from '../lib/supabase';

// If already signed in, bounce to home
const session = Astro.locals.session;
if (session) {
  return Astro.redirect('/');
}
---

<Base title="Sign in — The Orbital" description="Sign in to The Orbital">
  <div class="container">
    <div class="login-wrap">
      <h1 class="login-title">Sign in</h1>
      <p class="login-sub">The Orbital is currently invite-only. If you have an invitation, sign in below.</p>

      <button id="google-btn" class="google-btn">
        <svg class="google-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        Sign in with Google
      </button>

      <p class="login-note">Don't have an invitation? <a href="/contact">Get in touch</a>.</p>
    </div>
  </div>
</Base>

<script define:vars={{ SUPABASE_URL, SUPABASE_ANON_KEY }}>
  import { createBrowserClient } from '@supabase/ssr';

  const supabase = createBrowserClient(SUPABASE_URL, SUPABASE_ANON_KEY);

  document.getElementById('google-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('google-btn');
    if (btn) btn.disabled = true;

    const { error } = await supabase.auth.signInWithOAuth({
      provider: 'google',
      options: {
        redirectTo: `${window.location.origin}/auth/callback`,
      },
    });

    if (error) {
      console.error('OAuth error:', error);
      if (btn) btn.disabled = false;
    }
    // On success the browser navigates to Google — nothing else needed here
  });
</script>

<style>
.login-wrap {
  max-width: 420px;
  margin: 5rem auto;
  text-align: center;
  padding: 0 1rem;
}
.login-title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 2rem;
  font-weight: 400;
  margin-bottom: .75rem;
}
.login-sub {
  font-size: .9375rem;
  color: var(--text-2);
  line-height: 1.6;
  margin-bottom: 2rem;
}
.google-btn {
  display: inline-flex;
  align-items: center;
  gap: .75rem;
  padding: .75rem 1.5rem;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 6px;
  font-family: var(--font-sans);
  font-size: .9375rem;
  font-weight: 500;
  color: var(--text);
  cursor: pointer;
  transition: border-color .15s, box-shadow .15s;
}
.google-btn:hover {
  border-color: #aaa;
  box-shadow: 0 1px 4px rgba(0,0,0,.08);
}
.google-btn:disabled {
  opacity: .6;
  cursor: not-allowed;
}
.google-icon { width: 20px; height: 20px; flex-shrink: 0; }
.login-note {
  margin-top: 1.75rem;
  font-size: .8125rem;
  color: var(--text-3);
}
.login-note a { color: var(--text-2); }
.login-note a:hover { color: var(--text); }
</style>
