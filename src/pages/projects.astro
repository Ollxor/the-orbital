---
import Base from '../layouts/Base.astro';
import projectsData from '../data/projects.json';
import actorsData from '../data/actors.json';

const iconMap: Record<string, string> = {
  GARDEN:    'Icons2-01.svg',
  SPACESHIP: 'Icons2-04.svg',
  MYSTERIES: 'Icons2-03.svg',
  ASSEMBLY:  'Icons2-02.svg',
};
const orientationLabels: Record<string, string> = {
  GARDEN:    'The Garden',
  SPACESHIP: 'Spaceship Earth',
  MYSTERIES: 'The Mysteries',
  ASSEMBLY:  'The Assemblies',
};
const accentMap: Record<string, string> = {
  GARDEN:   '#4a7c59',
  SPACESHIP:'#2a6496',
  MYSTERIES:'#7b5ea7',
  ASSEMBLY: '#b8860b',
};
const orientations = ['GARDEN','SPACESHIP','MYSTERIES','ASSEMBLY'] as const;

// Status display config
const STATUS_COLOR: Record<string, string> = {
  active:    '#2e7d32',
  completed: '#64748b',
  planned:   '#b45309',
  paused:    '#1d4ed8',
  archived:  '#9ca3af',
};
const STATUS_LABEL: Record<string, string> = {
  active:    'Active',
  completed: 'Completed',
  planned:   'Planned',
  paused:    'Paused',
  archived:  'Archived',
};

// Status pills — count from data
const STATUS_ORDER = ['active','planned','completed','paused','archived'] as const;
const statusCounts: Record<string, number> = {};
STATUS_ORDER.forEach(s => { statusCounts[s] = 0; });
(projectsData as any[]).forEach((p: any) => {
  const s = (p.status ?? 'active').toLowerCase();
  statusCounts[s] = (statusCounts[s] ?? 0) + 1;
});

// Project type filter — only show if data exists
const PROJECT_TYPE_ORDER = ['campaign','platform','research','coalition','infrastructure','other'] as const;
const PROJECT_TYPE_LABELS: Record<string, string> = {
  campaign: 'Campaign', platform: 'Platform', research: 'Research',
  coalition: 'Coalition', infrastructure: 'Infrastructure', other: 'Other',
};
const projectTypeCounts: Record<string, number> = {};
PROJECT_TYPE_ORDER.forEach(t => { projectTypeCounts[t] = 0; });
(projectsData as any[]).forEach((p: any) => {
  const t = (p.project_type ?? '').toLowerCase();
  if (t) projectTypeCounts[t] = (projectTypeCounts[t] ?? 0) + 1;
});
const activeProjectTypes = PROJECT_TYPE_ORDER.filter(t => (projectTypeCounts[t] ?? 0) > 0);

// Scale filter — only show if data exists
const SCALE_ORDER = ['local','regional','national','continental','global'] as const;
const scaleCounts: Record<string, number> = {};
SCALE_ORDER.forEach(s => { scaleCounts[s] = 0; });
(projectsData as any[]).forEach((p: any) => {
  const s = (p.scale ?? '').toLowerCase();
  if (s) scaleCounts[s] = (scaleCounts[s] ?? 0) + 1;
});
const activeScales = SCALE_ORDER.filter(s => (scaleCounts[s] ?? 0) > 0);

// Continent filter — only show if data exists
const CONTINENT_ORDER = ['africa','north-america','latin-america','asia','europe','oceania','transnational'] as const;
const CONTINENT_LABELS: Record<string, string> = {
  'africa': 'Africa', 'north-america': 'N. America', 'latin-america': 'Latin America',
  'asia': 'Asia', 'europe': 'Europe', 'oceania': 'Oceania', 'transnational': 'Transnational',
};
const continentCounts: Record<string, number> = {};
CONTINENT_ORDER.forEach(c => { continentCounts[c] = 0; });
(projectsData as any[]).forEach((p: any) => {
  const c = (p.continent ?? '').toLowerCase();
  if (c) continentCounts[c] = (continentCounts[c] ?? 0) + 1;
});
const activeContinents = CONTINENT_ORDER.filter(c => (continentCounts[c] ?? 0) > 0);

const total = projectsData.length;
const actorMap = Object.fromEntries((actorsData as any[]).map((a: any) => [a.slug, a]));

function getFavicon(website: string): string {
  if (!website) return '';
  try { return `https://icons.duckduckgo.com/ip3/${new URL(website).hostname}.ico`; }
  catch { return ''; }
}

// Logo: prefer primary linked actor, fall back to project favicon
function getLogoInfo(project: any): { src: string; initial: string; accent: string } {
  const actor = project.actors?.length > 0 ? (actorMap as any)[project.actors[0]] : null;
  const website = actor?.website || project.website || '';
  const src = website ? getFavicon(website) : '';
  const name: string = actor?.name || project.name || '?';
  const orient: string = actor?.orientations?.[0] || project.orientations?.[0] || 'ASSEMBLY';
  return { src, initial: name.charAt(0).toUpperCase(), accent: accentMap[orient] ?? '#64748b' };
}
---

<Base title="Projects — The Orbital">
  <div class="projects-page">

    <div class="projects-header">
      <h1 class="projects-title">Projects</h1>
      <p class="projects-desc">Specific initiatives and experiments at the frontier of planetary governance.</p>
    </div>

    <p class="representation-note">
      A curated selection of projects at the frontier of planetary governance. We currently over-represent
      initiatives from Europe and North America — more to come.
      <a href="/contact">Suggest a project</a>.
    </p>

    <!-- Filter bar -->
    <div class="filter-bar" id="filter-bar">
      {orientations.map(key => (
        <button class="filter-btn active" data-orientation={key} aria-pressed="true">
          <img src={`/assets/${iconMap[key]}`} alt={orientationLabels[key]} class="filter-icon" />
          <span class="filter-label">{orientationLabels[key]}</span>
        </button>
      ))}
    </div>

    <div class="secondary-filters" id="secondary-filters">
      <div class="filter-row">
        <span class="filter-row-label">Status</span>
        <div class="filter-row-pills">
          {STATUS_ORDER.filter(s => statusCounts[s] > 0).map(s => (
            <button class="pill-btn active status-btn" data-status={s} aria-pressed="true">
              <span class="status-dot" style={`background:${STATUS_COLOR[s]}`}></span>
              {STATUS_LABEL[s]} <span class="pill-count">({statusCounts[s]})</span>
            </button>
          ))}
        </div>
      </div>

      {activeProjectTypes.length > 0 && (
        <div class="filter-row">
          <span class="filter-row-label">Type</span>
          <div class="filter-row-pills">
            {activeProjectTypes.map(t => (
              <button class="pill-btn active project-type-btn" data-project-type={t} aria-pressed="true">
                {PROJECT_TYPE_LABELS[t]} <span class="pill-count">({projectTypeCounts[t]})</span>
              </button>
            ))}
          </div>
        </div>
      )}

      {activeScales.length > 0 && (
        <div class="filter-row">
          <span class="filter-row-label">Scale</span>
          <div class="filter-row-pills">
            {activeScales.map(s => (
              <button class="pill-btn active scale-btn" data-scale={s} aria-pressed="true">
                {s.charAt(0).toUpperCase() + s.slice(1)} <span class="pill-count">({scaleCounts[s]})</span>
              </button>
            ))}
          </div>
        </div>
      )}

      {activeContinents.length > 0 && (
        <div class="filter-row">
          <span class="filter-row-label">Region</span>
          <div class="filter-row-pills">
            {activeContinents.map(c => (
              <button class="pill-btn active continent-btn" data-continent={c} aria-pressed="true">
                {CONTINENT_LABELS[c]} <span class="pill-count">({continentCounts[c]})</span>
              </button>
            ))}
          </div>
        </div>
      )}
    </div>

    <!-- Count -->
    <div class="count-row">
      <span class="project-count" id="project-count">{total} projects</span>
    </div>

    <!-- Grid -->
    <div class="projects-grid" id="projects-grid">
      {(projectsData as any[]).map((project: any) => {
        const status = (project.status ?? 'active').toLowerCase();
        const accentColor = STATUS_COLOR[status] ?? '#64748b';
        const logo = getLogoInfo(project);
        return (
          <a
            href={`/projects/${project.slug}`}
            class="project-card"
            data-orientations={project.orientations.join(',')}
            data-status={status}
            data-project-type={(project.project_type ?? '').toLowerCase()}
            data-scale={(project.scale ?? '').toLowerCase()}
            data-continent={(project.continent ?? '').toLowerCase()}
            style={`--accent:${accentColor}`}
          >
            <div class="card-body">
              <div class="card-top">
                <span class="card-status">
                  <span class="status-dot" style={`background:${accentColor}`}></span>
                  {STATUS_LABEL[status] ?? status}
                </span>
              </div>
              <h3 class="card-name">
                <div class="favicon-wrap sm" style={`--fav-accent:${logo.accent}`} data-initial={logo.initial}>
                  {logo.src && <img src={logo.src} alt="" referrerpolicy="no-referrer" onerror="this.remove()" loading="lazy" />}
                </div>
                {project.name}
              </h3>
              <p class="card-desc">{project.description}</p>
              {project.geography && (
                <p class="card-geo">
                  <svg class="geo-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path d="M8 1.5C5.5 1.5 3.5 3.5 3.5 6c0 3.5 4.5 8.5 4.5 8.5s4.5-5 4.5-8.5c0-2.5-2-4.5-4.5-4.5z"/>
                    <circle cx="8" cy="6" r="1.25"/>
                  </svg>
                  {project.geography}
                </p>
              )}
            </div>
            <div class="card-footer">
              <div class="card-tags">
                {(project.tags ?? []).slice(0, 3).map((tag: string) => (
                  <span class="card-tag">{tag.replace(/-/g, ' ')}</span>
                ))}
              </div>
              <div class="card-icons">
                {(project.orientations ?? []).map((o: string) => (
                  <img src={`/assets/${iconMap[o]}`} alt={orientationLabels[o]} class="card-orient-icon" title={orientationLabels[o]} />
                ))}
              </div>
            </div>
          </a>
        );
      })}
    </div>

    <p class="no-results" id="no-results" style="display:none">No projects match your current filters.</p>
  </div>
</Base>

<style>
/* ── Page ── */
.projects-page {
  max-width: 1300px;
  margin: 0 auto;
  padding: 2rem 2rem 4rem;
}
.projects-header { padding-bottom: 1rem; }
.projects-title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 2rem;
  font-weight: 400;
  margin-bottom: .5rem;
}
.projects-desc { font-size: .9375rem; color: var(--text-2); }

/* ── Transparency note ── */
.representation-note {
  font-size: .8125rem;
  color: var(--text-3);
  line-height: 1.6;
  margin: .75rem 0 1.5rem;
  font-style: italic;
}
.representation-note a { color: var(--text-2); font-weight: 600; text-decoration: none; }
.representation-note a:hover { text-decoration: underline; }

/* ── Filter bar (orientations) ── */
.filter-bar {
  display: flex;
  justify-content: center;
  gap: 2.5rem;
  flex-wrap: wrap;
  align-items: flex-start;
  padding: 1rem 1.5rem;
  background: var(--filter-bg);
  border-radius: 10px 10px 0 0;
  border-bottom: 1px solid var(--border);
}
.filter-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .35rem;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  opacity: 1;
  transition: transform .15s, opacity .15s;
}
.filter-btn:hover { transform: scale(1.08); }
.filter-btn:not(.active) { opacity: .28; }
.filter-icon { width: 32px; height: 32px; object-fit: contain; }
.filter-label { font-size: .6875rem; color: var(--text-3); white-space: nowrap; letter-spacing: .04em; }

/* ── Secondary filters ── */
.secondary-filters {
  display: flex;
  flex-direction: column;
  gap: .375rem;
  padding: .75rem 1.25rem;
  background: var(--filter-bg);
  border-radius: 0 0 10px 10px;
  margin-bottom: 1.5rem;
}
.filter-row { display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; }
.filter-row-label {
  font-family: var(--font-sans);
  font-size: .625rem;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--text-3);
  min-width: 44px;
  flex-shrink: 0;
}
.filter-row-pills { display: flex; flex-wrap: wrap; gap: .3rem; }
.pill-btn {
  display: flex;
  align-items: center;
  gap: .35rem;
  font-size: .6875rem;
  font-weight: 500;
  padding: .2rem .625rem;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: var(--bg);
  color: var(--text-3);
  cursor: pointer;
  transition: background .12s, color .12s, border-color .12s;
  line-height: 1.5;
  white-space: nowrap;
}
.pill-btn:hover { border-color: var(--text-2); color: var(--text-2); }
.pill-btn.active { background: var(--text); color: var(--bg); border-color: var(--text); }
.pill-btn.active:hover { opacity: .85; }
.pill-count { opacity: .65; font-size: .625rem; }
.pill-btn.active .pill-count { opacity: .8; }

/* ── Count row ── */
.count-row {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 1.5rem;
}
.project-count { font-size: .8125rem; color: var(--text-3); }

/* ── Grid ── */
.projects-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
}
@media (max-width: 1100px) { .projects-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 760px)  { .projects-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 480px)  { .projects-grid { grid-template-columns: 1fr; } }

/* ── Project card ── */
.project-card {
  position: relative;
  display: flex;
  flex-direction: column;
  border: 1px solid var(--border);
  border-top: 3px solid var(--accent, var(--border));
  border-radius: 0 0 10px 10px;
  background: var(--bg);
  text-decoration: none;
  color: inherit;
  overflow: hidden;
  transition: box-shadow .2s, transform .2s, border-color .2s;
}
.project-card:hover {
  box-shadow: 0 6px 20px rgba(0,0,0,.08);
  transform: translateY(-2px);
  border-top-color: var(--accent);
  text-decoration: none;
}
.project-card.hidden { display: none; }

/* ── Favicon with fallback initial ── */
.favicon-wrap {
  --fw: 22px;
  position: relative;
  width: var(--fw);
  height: var(--fw);
  border-radius: 3px;
  background: var(--fav-accent, #64748b);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.favicon-wrap::before {
  content: attr(data-initial);
  font-family: var(--font-sans);
  font-size: .5625rem;
  font-weight: 800;
  color: rgba(255,255,255,.9);
  line-height: 1;
}
.favicon-wrap img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
  border-radius: 2px;
  background: var(--bg);
}
.favicon-wrap.sm { --fw: 18px; }

/* ── Card body ── */
.card-body {
  padding: 1.125rem 1.25rem .75rem;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: .5rem;
}
.card-top { display: flex; align-items: center; gap: .5rem; }
.card-status {
  display: inline-flex;
  align-items: center;
  gap: .3rem;
  font-size: .625rem;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--text-3);
}
.status-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}
.card-name {
  display: flex;
  align-items: center;
  gap: .5rem;
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 1rem;
  font-weight: 400;
  line-height: 1.35;
  color: var(--text);
}
.card-desc {
  font-size: .8125rem;
  line-height: 1.65;
  color: var(--text-2);
  flex: 1;
}
.card-geo {
  display: flex;
  align-items: center;
  gap: .3rem;
  font-size: .75rem;
  color: var(--text-3);
  margin-top: .125rem;
}
.geo-icon { width: 11px; height: 11px; flex-shrink: 0; opacity: .6; }

/* ── Card footer ── */
.card-footer {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: .5rem;
  padding: .625rem 1.25rem .875rem;
  border-top: 1px solid var(--border);
  background: color-mix(in srgb, var(--accent) 3%, var(--bg));
}
.card-tags { display: flex; flex-wrap: wrap; gap: .25rem; flex: 1; }
.card-tag {
  font-size: .625rem;
  color: var(--text-3);
  background: var(--filter-bg);
  border: 1px solid var(--border);
  border-radius: 3px;
  padding: .1rem .35rem;
  white-space: nowrap;
}
.card-icons { display: flex; gap: .25rem; flex-shrink: 0; }
.card-orient-icon { width: 18px; height: 18px; object-fit: contain; opacity: .75; }

/* ── No results ── */
.no-results {
  text-align: center;
  padding: 3rem 0;
  font-size: .9375rem;
  color: var(--text-3);
}
</style>

<script>
// ── Filter state ────────────────────────────────────────────────────────────
const ORIENTATIONS = ['GARDEN','SPACESHIP','MYSTERIES','ASSEMBLY'];
let activeOrientations = new Set(ORIENTATIONS);
let activeStatuses     = new Set<string>();
let activeProjectTypes = new Set<string>();
let activeScales       = new Set<string>();
let activeContinents   = new Set<string>();

// Init from rendered pills
document.querySelectorAll<HTMLElement>('.status-btn').forEach(b => activeStatuses.add(b.dataset.status!));
document.querySelectorAll<HTMLElement>('.project-type-btn').forEach(b => activeProjectTypes.add(b.dataset.projectType!));
document.querySelectorAll<HTMLElement>('.scale-btn').forEach(b => activeScales.add(b.dataset.scale!));
document.querySelectorAll<HTMLElement>('.continent-btn').forEach(b => activeContinents.add(b.dataset.continent!));

const projectTypeBtns  = document.querySelectorAll<HTMLElement>('.project-type-btn');
const scaleBtns        = document.querySelectorAll<HTMLElement>('.scale-btn');
const continentBtns    = document.querySelectorAll<HTMLElement>('.continent-btn');

// ── Helpers ─────────────────────────────────────────────────────────────────
function pushURL() {
  const params = new URLSearchParams();
  if (activeOrientations.size < ORIENTATIONS.length) params.set('o', [...activeOrientations].join(','));
  const allSt = [...document.querySelectorAll<HTMLElement>('.status-btn')].map(b => b.dataset.status!);
  if (activeStatuses.size < allSt.length) params.set('st', [...activeStatuses].join(','));
  const qs = params.toString();
  history.replaceState(null, '', qs ? '?' + qs : location.pathname);
}

function applyFilters() {
  const cards = document.querySelectorAll<HTMLElement>('.project-card');
  let visible = 0;
  cards.forEach(card => {
    const orients = (card.dataset.orientations || '').split(',').filter(Boolean);
    const passO  = orients.length === 0 || orients.some(o => activeOrientations.has(o));
    const passSt = activeStatuses.has(card.dataset.status ?? '');
    const passPT = projectTypeBtns.length === 0 || activeProjectTypes.size === 0
                   || activeProjectTypes.has(card.dataset.projectType ?? '');
    const passSc = scaleBtns.length === 0 || activeScales.size === 0
                   || activeScales.has(card.dataset.scale ?? '');
    const passC  = continentBtns.length === 0 || activeContinents.size === 0
                   || activeContinents.has(card.dataset.continent ?? '');
    const show = passO && passSt && passPT && passSc && passC;
    card.classList.toggle('hidden', !show);
    if (show) visible++;
  });
  const countEl = document.getElementById('project-count');
  if (countEl) countEl.textContent = visible + ' project' + (visible !== 1 ? 's' : '');
  const noResults = document.getElementById('no-results');
  if (noResults) noResults.style.display = visible === 0 ? '' : 'none';
}

function syncButtons() {
  document.querySelectorAll<HTMLElement>('.filter-btn[data-orientation]').forEach(btn => {
    const active = activeOrientations.has(btn.dataset.orientation!);
    btn.classList.toggle('active', active);
    btn.setAttribute('aria-pressed', String(active));
  });
  document.querySelectorAll<HTMLElement>('.status-btn').forEach(btn => {
    const active = activeStatuses.has(btn.dataset.status!);
    btn.classList.toggle('active', active);
    btn.setAttribute('aria-pressed', String(active));
  });
  projectTypeBtns.forEach(btn => {
    const active = activeProjectTypes.has(btn.dataset.projectType!);
    btn.classList.toggle('active', active);
    btn.setAttribute('aria-pressed', String(active));
  });
  scaleBtns.forEach(btn => {
    const active = activeScales.has(btn.dataset.scale!);
    btn.classList.toggle('active', active);
    btn.setAttribute('aria-pressed', String(active));
  });
  continentBtns.forEach(btn => {
    const active = activeContinents.has(btn.dataset.continent!);
    btn.classList.toggle('active', active);
    btn.setAttribute('aria-pressed', String(active));
  });
}

// ── Init from URL ────────────────────────────────────────────────────────────
(function initFromURL() {
  const params = new URLSearchParams(location.search);
  const o  = params.get('o');
  const st = params.get('st');
  if (o)  activeOrientations = new Set(o.split(',').filter(x => ORIENTATIONS.includes(x)));
  if (st) {
    const allSt = [...document.querySelectorAll<HTMLElement>('.status-btn')].map(b => b.dataset.status!);
    activeStatuses = new Set(st.split(',').filter(x => allSt.includes(x)));
  }
  syncButtons();
  applyFilters();
})();

// ── Orientation buttons ──────────────────────────────────────────────────────
document.getElementById('filter-bar')!.addEventListener('click', e => {
  const btn = (e.target as Element).closest<HTMLElement>('.filter-btn[data-orientation]');
  if (!btn) return;
  const key = btn.dataset.orientation!;
  if (activeOrientations.has(key)) {
    if (activeOrientations.size === 1) activeOrientations = new Set(ORIENTATIONS);
    else activeOrientations.delete(key);
  } else {
    activeOrientations.add(key);
  }
  syncButtons(); applyFilters(); pushURL();
});

// ── Secondary filter buttons ─────────────────────────────────────────────────
document.getElementById('secondary-filters')!.addEventListener('click', e => {
  const target = e.target as Element;

  const statusBtn = target.closest<HTMLElement>('.status-btn');
  if (statusBtn) {
    const key = statusBtn.dataset.status!;
    if (activeStatuses.has(key)) {
      if (activeStatuses.size === 1) document.querySelectorAll<HTMLElement>('.status-btn').forEach(b => activeStatuses.add(b.dataset.status!));
      else activeStatuses.delete(key);
    } else activeStatuses.add(key);
    syncButtons(); applyFilters(); pushURL(); return;
  }

  const ptBtn = target.closest<HTMLElement>('.project-type-btn');
  if (ptBtn) {
    const key = ptBtn.dataset.projectType!;
    if (activeProjectTypes.has(key)) {
      if (activeProjectTypes.size === 1) projectTypeBtns.forEach(b => activeProjectTypes.add(b.dataset.projectType!));
      else activeProjectTypes.delete(key);
    } else activeProjectTypes.add(key);
    syncButtons(); applyFilters(); return;
  }

  const scaleBtn = target.closest<HTMLElement>('.scale-btn');
  if (scaleBtn) {
    const key = scaleBtn.dataset.scale!;
    if (activeScales.has(key)) {
      if (activeScales.size === 1) scaleBtns.forEach(b => activeScales.add(b.dataset.scale!));
      else activeScales.delete(key);
    } else activeScales.add(key);
    syncButtons(); applyFilters(); return;
  }

  const contBtn = target.closest<HTMLElement>('.continent-btn');
  if (contBtn) {
    const key = contBtn.dataset.continent!;
    if (activeContinents.has(key)) {
      if (activeContinents.size === 1) continentBtns.forEach(b => activeContinents.add(b.dataset.continent!));
      else activeContinents.delete(key);
    } else activeContinents.add(key);
    syncButtons(); applyFilters(); return;
  }
});
</script>
