---
import Base from '../layouts/Base.astro';
import newsData from '../data/news.json';
import actorsData from '../data/actors.json';
import projectsData from '../data/projects.json';
import eventsData from '../data/events.json';

// Build a flat search index
type IndexItem = { kind: string; url: string; title: string; text: string; meta?: string };
const index: IndexItem[] = [];

for (const n of newsData) {
  index.push({
    kind: 'news',
    url: `/news/${n.slug}`,
    title: n.title,
    text: `${n.summary || ''} ${(n.tags || []).join(' ')}`,
    meta: new Date(n.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }),
  });
}
for (const a of actorsData) {
  index.push({
    kind: 'actor',
    url: `/actors/${a.slug}`,
    title: a.name,
    text: `${a.description || ''} ${(a.tags || []).join(' ')} ${a.location || ''}`,
    meta: a.type || '',
  });
}
for (const p of projectsData) {
  index.push({
    kind: 'project',
    url: `/projects/${p.slug}`,
    title: p.name,
    text: `${p.description || ''} ${(p.tags || []).join(' ')} ${p.geography || ''}`,
    meta: p.stage || '',
  });
}
for (const e of eventsData) {
  index.push({
    kind: 'event',
    url: e.website || '#',
    title: e.name,
    text: `${e.description || ''} ${(e.tags || []).join(' ')} ${e.location || ''}`,
    meta: e.date_start ? new Date(e.date_start).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) : '',
  });
}
---

<Base title="Search — The Orbital">
  <div class="container">
    <div class="page-header">
      <h1 class="page-title">Search</h1>
      <p class="page-desc">Search across news, actors, projects, and events.</p>
    </div>

    <div class="search-box">
      <input type="search" id="q" placeholder="Try 'assembly', 'ocean', 'Taiwan'…" autofocus autocomplete="off" />
      <div class="facets" id="facets">
        <label><input type="checkbox" value="news" checked /> News</label>
        <label><input type="checkbox" value="actor" checked /> Actors</label>
        <label><input type="checkbox" value="project" checked /> Projects</label>
        <label><input type="checkbox" value="event" checked /> Events</label>
      </div>
    </div>

    <p class="hint" id="hint">Type at least 2 characters…</p>
    <div class="results" id="results"></div>
  </div>
</Base>

<script id="search-index" type="application/json" set:html={JSON.stringify(index)}></script>

<style>
.page-header { padding: 2rem 0 1rem; }
.page-title { font-family: var(--font-serif); font-size: 1.75rem; font-weight: normal; margin-bottom: .375rem; }
.page-desc { font-size: .9375rem; color: var(--text-2); }

.search-box { margin: 1rem 0 1.5rem; }
#q {
  width: 100%;
  padding: .75rem 1rem;
  font-size: 1rem;
  border: 1px solid var(--border);
  border-radius: 8px;
  background: var(--bg);
  color: var(--text);
  outline: none;
  font-family: inherit;
}
#q:focus { border-color: var(--text-2); }

.facets { display: flex; gap: 1.25rem; margin-top: .75rem; flex-wrap: wrap; }
.facets label { font-size: .8125rem; color: var(--text-2); cursor: pointer; user-select: none; }
.facets input { margin-right: .25rem; vertical-align: middle; }

.hint { color: var(--text-3); font-size: .875rem; padding: 1rem 0; }

.group-heading {
  font-family: var(--font-sans);
  font-size: .6875rem;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--text-3);
  margin: 1.75rem 0 .75rem;
  padding-bottom: .4rem;
  border-bottom: 1px solid var(--border);
}
.group-heading .group-count { color: var(--text-3); font-weight: 400; margin-left: .25rem; }

.results { display: flex; flex-direction: column; gap: .25rem; }

.result {
  display: grid;
  grid-template-columns: 8px 1fr;
  gap: .875rem;
  padding: 1rem 1rem 1rem .25rem;
  border-radius: 6px;
  transition: background .12s;
}
.result:hover { background: var(--filter-bg); }
.result-accent { border-radius: 2px; background: var(--text-3); }
.result.news    .result-accent { background: var(--spaceship); }
.result.actor   .result-accent { background: var(--garden); }
.result.project .result-accent { background: var(--mysteries); }
.result.event   .result-accent { background: var(--assemblies); }

.result-head { display: flex; align-items: baseline; gap: .625rem; flex-wrap: wrap; margin-bottom: .25rem; }
.result-kind {
  font-size: .625rem;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  padding: .15rem .5rem;
  border-radius: 999px;
  background: var(--filter-bg);
  color: var(--text-2);
  flex-shrink: 0;
}
.result.news    .result-kind { background: #e4edf5; color: var(--spaceship); }
.result.actor   .result-kind { background: #e7f1ea; color: var(--garden); }
.result.project .result-kind { background: #ece4f3; color: var(--mysteries); }
.result.event   .result-kind { background: #f5ecd8; color: var(--assemblies); }

.result-title {
  font-family: 'Source Serif 4', Georgia, serif;
  font-size: 1.125rem;
  font-weight: 400;
  line-height: 1.3;
  color: var(--text);
  flex: 1;
  min-width: 0;
}
.result-title a { text-decoration: none; color: inherit; }
.result-title a:hover { color: var(--text); text-decoration: underline; text-underline-offset: 3px; }

.result-meta {
  font-size: .75rem;
  color: var(--text-3);
  margin-bottom: .375rem;
}
.result-snippet {
  font-size: .875rem;
  color: var(--text-2);
  line-height: 1.6;
  font-family: 'Source Serif 4', Georgia, serif;
  font-weight: 300;
}
.result mark {
  background: rgba(255, 221, 0, .35);
  color: inherit;
  padding: 0 .15em;
  border-radius: 2px;
  font-weight: 500;
}

.summary-bar {
  font-size: .8125rem;
  color: var(--text-3);
  padding: .75rem 0;
  display: flex;
  gap: .75rem;
  flex-wrap: wrap;
}
.summary-bar .sep { color: var(--border); }
.summary-bar strong { color: var(--text-2); font-weight: 600; }
</style>

<script>
  type Item = { kind: string; url: string; title: string; text: string; meta?: string };
  const raw = document.getElementById('search-index')!.textContent || '[]';
  const items: Item[] = JSON.parse(raw);
  const input = document.getElementById('q') as HTMLInputElement;
  const results = document.getElementById('results')!;
  const hint = document.getElementById('hint')!;
  const facets = document.querySelectorAll('#facets input') as NodeListOf<HTMLInputElement>;

  function escapeHtml(s: string) {
    return s.replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]!));
  }
  function highlight(s: string, q: string) {
    if (!q) return escapeHtml(s);
    const re = new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
    return escapeHtml(s).replace(re, '<mark>$1</mark>');
  }
  function snippet(text: string, q: string, len = 160) {
    if (!text) return '';
    const lower = text.toLowerCase();
    const i = lower.indexOf(q.toLowerCase());
    if (i < 0) return text.slice(0, len) + (text.length > len ? '…' : '');
    const start = Math.max(0, i - 40);
    const end = Math.min(text.length, i + q.length + 120);
    return (start > 0 ? '…' : '') + text.slice(start, end) + (end < text.length ? '…' : '');
  }

  function activeKinds() {
    const s = new Set<string>();
    facets.forEach(f => { if (f.checked) s.add(f.value); });
    return s;
  }

  const kindLabel: Record<string, string> = { news: 'News', actor: 'Actors', project: 'Projects', event: 'Events' };
  const kindOrder = ['news', 'actor', 'project', 'event'];

  function resultHtml(item: Item, q: string) {
    const external = item.kind === 'event' ? ' target="_blank" rel="noopener"' : '';
    const snippetHtml = item.text ? `<div class="result-snippet">${highlight(snippet(item.text, q), q)}</div>` : '';
    const metaHtml = item.meta ? `<div class="result-meta">${escapeHtml(item.meta)}</div>` : '';
    return `
      <div class="result ${item.kind}">
        <div class="result-accent"></div>
        <div class="result-body">
          <div class="result-head">
            <span class="result-kind">${kindLabel[item.kind] || item.kind}</span>
            <h3 class="result-title"><a href="${item.url}"${external}>${highlight(item.title, q)}</a></h3>
          </div>
          ${metaHtml}
          ${snippetHtml}
        </div>
      </div>
    `;
  }

  function render() {
    const q = input.value.trim();
    if (q.length < 2) {
      hint.style.display = 'block';
      hint.textContent = 'Type at least 2 characters…';
      results.innerHTML = '';
      return;
    }
    const kinds = activeKinds();
    const ql = q.toLowerCase();
    const scored: { item: Item; score: number }[] = [];
    for (const it of items) {
      if (!kinds.has(it.kind)) continue;
      const titleIdx = it.title.toLowerCase().indexOf(ql);
      const textIdx = it.text.toLowerCase().indexOf(ql);
      if (titleIdx < 0 && textIdx < 0) continue;
      let score = 0;
      if (titleIdx >= 0) score += 100 - titleIdx;
      if (textIdx >= 0) score += 20;
      scored.push({ item: it, score });
    }
    scored.sort((a, b) => b.score - a.score);
    const top = scored.slice(0, 120);
    if (top.length === 0) {
      hint.style.display = 'block';
      hint.textContent = `No results for "${q}".`;
      results.innerHTML = '';
      return;
    }
    hint.style.display = 'none';

    // Group by kind, preserving score order within each group
    const grouped: Record<string, Item[]> = {};
    for (const { item } of top) {
      (grouped[item.kind] ||= []).push(item);
    }

    const summaryParts: string[] = [];
    for (const k of kindOrder) {
      if (grouped[k]?.length) summaryParts.push(`<span><strong>${grouped[k].length}</strong> ${kindLabel[k].toLowerCase()}</span>`);
    }
    const summaryBar = `<div class="summary-bar">${summaryParts.join('<span class="sep">·</span>')}</div>`;

    const sections = kindOrder
      .filter(k => grouped[k]?.length)
      .map(k => {
        const items = grouped[k];
        const body = items.map(it => resultHtml(it, q)).join('');
        return `<h2 class="group-heading">${kindLabel[k]} <span class="group-count">(${items.length})</span></h2><div class="results">${body}</div>`;
      })
      .join('');

    results.innerHTML = summaryBar + sections;
  }

  input.addEventListener('input', render);
  facets.forEach(f => f.addEventListener('change', render));

  // Honor ?q= in URL
  const params = new URLSearchParams(location.search);
  const initial = params.get('q');
  if (initial) { input.value = initial; render(); }
</script>
