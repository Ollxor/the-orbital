---
import Base from '../../layouts/Base.astro';
import newsData from '../../data/news.json';
import actorsData from '../../data/actors.json';
import projectsData from '../../data/projects.json';
import eventsData from '../../data/events.json';

export function getStaticPaths() {
  const tags = new Set<string>();
  for (const n of newsData) n.tags?.forEach((t: string) => tags.add(t));
  for (const a of actorsData) a.tags?.forEach((t: string) => tags.add(t));
  for (const p of projectsData) p.tags?.forEach((t: string) => tags.add(t));
  for (const e of eventsData) e.tags?.forEach((t: string) => tags.add(t));
  return Array.from(tags).map(tag => ({ params: { tag } }));
}

const { tag } = Astro.params;
const tagLabel = tag!.replace(/-/g, ' ');

const news = newsData
  .filter(n => n.tags?.includes(tag!))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const actors = actorsData.filter(a => a.tags?.includes(tag!));
const projects = projectsData.filter(p => p.tags?.includes(tag!));
const events = eventsData.filter(e => e.tags?.includes(tag!));

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}

const total = news.length + actors.length + projects.length + events.length;
---

<Base title={`#${tagLabel} — The Orbital`} description={`Everything tagged ${tagLabel}.`}>
  <div class="container">
    <div class="tag-header">
      <p class="tag-eyebrow">Tag</p>
      <h1 class="tag-title">#{tagLabel}</h1>
      <p class="tag-count">{total} item{total !== 1 ? 's' : ''}</p>
    </div>

    {news.length > 0 && (
      <section>
        <h2 class="section-heading">News <span class="count">({news.length})</span></h2>
        {news.map(s => (
          <article class="item news">
            <time class="item-date">{formatDate(s.date)}</time>
            <h3 class="item-title"><a href={`/news/${s.slug}`}>{s.title}</a></h3>
            <p class="item-desc">{s.summary}</p>
          </article>
        ))}
      </section>
    )}

    {actors.length > 0 && (
      <section>
        <h2 class="section-heading">Actors <span class="count">({actors.length})</span></h2>
        {actors.map(a => (
          <article class="item">
            <h3 class="item-title"><a href={`/actors/${a.slug}`}>{a.name}</a></h3>
            <p class="item-desc">{a.description}</p>
          </article>
        ))}
      </section>
    )}

    {projects.length > 0 && (
      <section>
        <h2 class="section-heading">Projects <span class="count">({projects.length})</span></h2>
        {projects.map(p => (
          <article class="item">
            <h3 class="item-title"><a href={`/projects/${p.slug}`}>{p.name}</a></h3>
            <p class="item-desc">{p.description}</p>
          </article>
        ))}
      </section>
    )}

    {events.length > 0 && (
      <section>
        <h2 class="section-heading">Events <span class="count">({events.length})</span></h2>
        {events.map(e => (
          <article class="item">
            {e.date_start && <time class="item-date">{formatDate(e.date_start)} · {e.location}</time>}
            <h3 class="item-title"><a href={e.website} target="_blank" rel="noopener">{e.name}</a></h3>
            <p class="item-desc">{e.description}</p>
          </article>
        ))}
      </section>
    )}

    {total === 0 && <p class="empty">Nothing tagged #{tagLabel} yet.</p>}

    <a href="/" class="back-link">← Back to feed</a>
  </div>
</Base>

<style>
.tag-header { padding: 2.5rem 0 1.5rem; border-bottom: 3px double var(--border); margin-bottom: 1.5rem; }
.tag-eyebrow { font-family: var(--font-sans); font-size: .6875rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--text-3); margin-bottom: .375rem; }
.tag-title { font-family: 'Playfair Display', Georgia, serif; font-size: 2rem; font-weight: 400; line-height: 1.2; margin-bottom: .25rem; }
.tag-count { font-size: .8125rem; color: var(--text-3); }

.section-heading {
  font-family: var(--font-sans);
  font-size: .6875rem;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--text-3);
  margin: 1.75rem 0 1rem;
  padding-bottom: .5rem;
  border-bottom: 1px solid var(--border);
}
.section-heading .count { color: var(--text-3); font-weight: 400; margin-left: .25rem; }

.item { padding: .875rem 0; border-bottom: 1px solid var(--border); }
.item-date { display: block; font-size: .75rem; color: var(--text-3); margin-bottom: .25rem; }
.item-title { font-family: 'Source Serif 4', Georgia, serif; font-size: 1.0625rem; font-weight: 400; line-height: 1.35; margin-bottom: .25rem; }
.item-title a { text-decoration: none; }
.item-title a:hover { text-decoration: underline; }
.item-desc { font-size: .875rem; color: var(--text-2); line-height: 1.55; }

.empty { padding: 2rem 0; color: var(--text-3); }
.back-link { display: inline-block; margin-top: 2rem; font-size: .875rem; color: var(--text-2); text-decoration: none; }
.back-link:hover { color: var(--text); }
</style>
