---
interface Props {
  title: string;
  description?: string;
  currentPath?: string;
  noindex?: boolean;
}
const { title, description, currentPath, noindex } = Astro.props;

const defaultDescription = 'A living map of the movements building planetary governance — through ecology, technology, play, ritual, and democratic innovation.';

const navItems = [
  { href: '/', label: 'Feed' },
  { href: '/about', label: 'About' },
  { href: '/actors', label: 'Actors' },
  { href: '/projects', label: 'Projects' },
  { href: '/events', label: 'Events' },
  { href: '/tags', label: 'Tags' },
  { href: '/graph', label: 'Graph' },
  { href: '/join', label: 'Join' },
];

import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description || defaultDescription} />
  {noindex && <meta name="robots" content="noindex" />}
  <meta property="og:title" content={`${title} · The Overview`} />
  <meta property="og:description" content={description || defaultDescription} />
  <meta property="og:site_name" content="The Overview" />
  <title>{title} · The Overview</title>
  <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js"
    integrity="sha384-/TgkGk7p307TH7EXJDuUlgG3Ce1UVolAOFopFekQkkXihi5u/6OCvVKyz1W+idaz"
    crossorigin="anonymous"></script>
</head>
<body>
  <div class="site-wrapper">
    <header class="site-header reveal reveal-1">
      <div class="site-header__inner">
        <a href="/" class="site-title">The Overview</a>
        <nav class="site-nav">
          {navItems.map(item => (
            <a
              href={item.href}
              aria-current={currentPath === item.href ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class="reveal reveal-2">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <p>The Overview — Prototyping Our Way Towards Paradise</p>
        <p><a href="/about">About</a></p>
      </div>
    </footer>
  </div>
</body>
</html>
