---
import Base from '../layouts/Base.astro';
import { getAllCategories, ORIENTATION_COLORS } from '../lib/db';

const categories = getAllCategories();

// Group by orientation
const grouped = new Map<string, typeof categories>();
for (const cat of categories) {
  const code = cat.orientation_code || 'OTHER';
  if (!grouped.has(code)) grouped.set(code, []);
  grouped.get(code)!.push(cat);
}
---
<Base title="Categories" currentPath="/categories">
  <div class="section-heading reveal reveal-2">Categories</div>
  <p class="meta reveal reveal-2" style="margin-bottom:var(--sp-8)">
    {categories.length} research categories across {grouped.size} orientations
  </p>

  {[...grouped.entries()].map(([code, cats]) => {
    const color = ORIENTATION_COLORS[code] || '#71717a';
    return (
      <div class="reveal reveal-3" style="margin-bottom:var(--sp-8)">
        <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:var(--sp-4)">
          <span style={`width:8px;height:8px;border-radius:50%;background:${color}`}></span>
          <a href={`/orientations/${code}`} class="section-heading" style="margin-bottom:0">{code}</a>
        </div>
        <div class="card-grid card-grid--3" style="gap:0.75rem">
          {cats.map(cat => (
            <a href={`/orientations/${code}#${cat.name.toLowerCase().replace(/\s+/g, '-')}`}
               class="card card--link" style="padding:var(--sp-4) var(--sp-5)">
              <div style="font-family:var(--font-display);font-size:var(--text-base);line-height:1.3">{cat.name}</div>
              <div class="meta" style="margin-top:0.25rem">{cat.actor_count || 0} actors</div>
              {cat.description && (
                <div class="meta" style="margin-top:0.25rem;font-size:var(--text-xs);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">
                  {cat.description}
                </div>
              )}
            </a>
          ))}
        </div>
      </div>
    );
  })}
</Base>
