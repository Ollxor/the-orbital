---
import Base from '../../layouts/Base.astro';
import {
  getAllEvents, getEvent, getEventActors, getRelatedEvents,
  ORIENTATION_COLORS, EVENT_TYPE_ICONS,
} from '../../lib/db';

export function getStaticPaths() {
  const events = getAllEvents();
  return events.map(e => ({ params: { id: String(e.id) } }));
}

const { id } = Astro.params;
const eventId = Number(id);
const event = getEvent(eventId);

if (!event) return Astro.redirect('/events');

const actors = getEventActors(eventId);
const related = getRelatedEvents(eventId, 6);

const icon = EVENT_TYPE_ICONS[event.type || 'Other'] || '\u25CB';

function formatDateDisplay(dateStr: string | null): string {
  if (!dateStr) return 'Date TBD';
  if (dateStr === 'upcoming') return 'Upcoming';
  const months = ['', 'January', 'February', 'March', 'April', 'May', 'June',
                  'July', 'August', 'September', 'October', 'November', 'December'];
  if (dateStr.length >= 7) {
    const monthNum = parseInt(dateStr.substring(5, 7));
    const monthName = months[monthNum] || '';
    return `${monthName} ${dateStr.substring(0, 4)}`;
  }
  return dateStr;
}

// Group actors by role
const organizers = actors.filter(a => a.role === 'organizer');
const speakers = actors.filter(a => a.role === 'speaker');
const attendees = actors.filter(a => a.role === 'attendee');
const sponsors = actors.filter(a => a.role === 'sponsor');
const others = actors.filter(a => !['organizer', 'speaker', 'attendee', 'sponsor'].includes(a.role || ''));

interface RoleGroup { label: string; actors: typeof actors; accent: string; }
const roleGroups: RoleGroup[] = [
  { label: 'Organisers', actors: organizers, accent: 'var(--green)' },
  { label: 'Speakers', actors: speakers, accent: 'var(--orient-assembly)' },
  { label: 'Sponsors', actors: sponsors, accent: 'var(--orient-temple)' },
  { label: 'Attendees', actors: attendees, accent: 'var(--orient-spaceship)' },
  { label: 'Participants', actors: others, accent: 'var(--zinc)' },
].filter(g => g.actors.length > 0);

const dateDisplay = formatDateDisplay(event.date_start);
const endDisplay = event.date_end ? formatDateDisplay(event.date_end) : null;
---
<Base title={event.name}>
  <a href="/events" class="back-link">&larr; Events</a>

  <!-- Event header -->
  <div class="event-header reveal reveal-1">
    <div class="event-header__icon-ring">
      <span class="event-header__icon">{icon}</span>
    </div>

    <div class="event-header__eyebrow">
      {event.type && <span class="event-header__type">{event.type}</span>}
      {event.series && (
        <span class="event-header__series">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polyline points="17 1 21 5 17 9"/>
            <path d="M3 11V9a4 4 0 014-4h14"/>
          </svg>
          {event.series}
          {event.edition && <span> &middot; Edition {event.edition}</span>}
        </span>
      )}
    </div>

    <h1 class="event-header__title">{event.name}</h1>

    <div class="event-header__details">
      <div class="event-header__detail">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        <span>{dateDisplay}{endDisplay ? ` \u2013 ${endDisplay}` : ''}</span>
      </div>

      {event.location && (
        <div class="event-header__detail">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
            <circle cx="12" cy="9" r="2.5"/>
          </svg>
          <span>{event.location}</span>
        </div>
      )}

      {event.recurrence && event.recurrence !== 'one-off' && (
        <div class="event-header__detail">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <polyline points="23 4 23 10 17 10"/>
            <polyline points="1 20 1 14 7 14"/>
            <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/>
          </svg>
          <span style="text-transform:capitalize">{event.recurrence}</span>
        </div>
      )}
    </div>

    {event.website && (
      <a href={event.website} target="_blank" rel="noopener" class="event-header__website">
        Visit event website
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
          <polyline points="15 3 21 3 21 9"/>
          <line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
      </a>
    )}
  </div>

  <div class="event-body">
    <!-- Left: Description & notes -->
    <div class="event-body__main reveal reveal-2">
      {event.description && (
        <div class="event-section">
          <div class="event-section__label">About this event</div>
          <p class="event-section__text">{event.description}</p>
        </div>
      )}

      {event.relevance_note && (
        <div class="event-section">
          <div class="event-section__label">Relevance to The Garden</div>
          <p class="event-section__text">{event.relevance_note}</p>
        </div>
      )}

      <!-- Participating actors by role -->
      {roleGroups.length > 0 && (
        <div class="event-section">
          <div class="event-section__label">Participating Actors</div>
          <div class="event-actors">
            {roleGroups.map(group => (
              <div class="event-actors__group">
                <div class="event-actors__role" style={`--accent: ${group.accent}`}>
                  {group.label}
                </div>
                <div class="event-actors__list">
                  {group.actors.map(actor => {
                    const orientColor = actor.orientation_code
                      ? ORIENTATION_COLORS[actor.orientation_code] || '#71717a'
                      : '#71717a';
                    return (
                      <a href={`/actors/${actor.actor_id}`} class="event-actor-card">
                        <div class="event-actor-card__orient" style={`background: ${orientColor}`}></div>
                        <div class="event-actor-card__info">
                          <div class="event-actor-card__name">{actor.actor_name}</div>
                          <div class="event-actor-card__meta">
                            {actor.actor_type}
                            {actor.actor_location && ` \u00B7 ${actor.actor_location}`}
                          </div>
                        </div>
                        {actor.orientation_name && (
                          <div class="event-actor-card__orientation" style={`color: ${orientColor}`}>
                            {actor.orientation_name}
                          </div>
                        )}
                      </a>
                    );
                  })}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>

    <!-- Right: Sidebar -->
    <aside class="event-body__sidebar reveal reveal-3">
      <div class="event-sidebar-card">
        <div class="event-sidebar-card__header">
          <span class="event-sidebar-card__icon">{icon}</span>
          <span class="event-sidebar-card__type">{event.type || 'Event'}</span>
        </div>

        <div class="event-sidebar-card__field">
          <span class="event-sidebar-card__label">Date</span>
          <span class="event-sidebar-card__value">{dateDisplay}</span>
        </div>

        {event.location && (
          <div class="event-sidebar-card__field">
            <span class="event-sidebar-card__label">Location</span>
            <span class="event-sidebar-card__value">{event.location}</span>
          </div>
        )}

        {event.series && (
          <div class="event-sidebar-card__field">
            <span class="event-sidebar-card__label">Series</span>
            <span class="event-sidebar-card__value">{event.series}</span>
          </div>
        )}

        {event.edition && (
          <div class="event-sidebar-card__field">
            <span class="event-sidebar-card__label">Edition</span>
            <span class="event-sidebar-card__value">{event.edition}</span>
          </div>
        )}

        {event.recurrence && (
          <div class="event-sidebar-card__field">
            <span class="event-sidebar-card__label">Recurrence</span>
            <span class="event-sidebar-card__value" style="text-transform:capitalize">{event.recurrence}</span>
          </div>
        )}

        <div class="event-sidebar-card__field">
          <span class="event-sidebar-card__label">Actors linked</span>
          <span class="event-sidebar-card__value">{actors.length}</span>
        </div>

        <div class="event-sidebar-card__field">
          <span class="event-sidebar-card__label">ID</span>
          <span class="event-sidebar-card__value mono" style="font-family:var(--font-mono);font-size:var(--text-xs)">
            EVT-{String(event.id).padStart(3, '0')}
          </span>
        </div>
      </div>

      <!-- Related events -->
      {related.length > 0 && (
        <div class="event-related">
          <div class="event-related__label">Related Events</div>
          {related.map(rel => {
            const relIcon = EVENT_TYPE_ICONS[rel.type || 'Other'] || '\u25CB';
            return (
              <a href={`/events/${rel.id}`} class="event-related__item">
                <span class="event-related__icon">{relIcon}</span>
                <span class="event-related__info">
                  <span class="event-related__name">{rel.name}</span>
                  <span class="event-related__meta">
                    {rel.type}{rel.date_start && rel.date_start !== 'upcoming' ? ` \u00B7 ${rel.date_start.substring(0, 4)}` : ''}
                  </span>
                </span>
              </a>
            );
          })}
        </div>
      )}
    </aside>
  </div>
</Base>

<style>
  /* ═══════════════════════════════════════════════════════
     EVENT DETAIL PAGE
     ═══════════════════════════════════════════════════════ */

  /* ─── Back link ────────────────────────────────────────── */

  .back-link {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--zinc);
    margin-bottom: var(--sp-8);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .back-link:hover {
    color: var(--green-deep);
  }

  /* ─── Header ───────────────────────────────────────────── */

  .event-header {
    margin-bottom: var(--sp-12);
    max-width: 48rem;
  }

  .event-header__icon-ring {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--green-wash), var(--cream-dark));
    border: 2px solid var(--sand-warm);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--sp-6);
  }

  .event-header__icon {
    font-size: 1.1rem;
    color: var(--green-deep);
  }

  .event-header__eyebrow {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    margin-bottom: var(--sp-3);
    flex-wrap: wrap;
  }

  .event-header__type {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--green);
  }

  .event-header__series {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--sand-deep);
  }

  .event-header__series svg {
    color: var(--sand-warm);
  }

  .event-header__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--charcoal);
    margin-bottom: var(--sp-6);
  }

  .event-header__details {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-6);
    margin-bottom: var(--sp-6);
  }

  .event-header__detail {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--text-sm);
    color: var(--charcoal-soft);
  }

  .event-header__detail svg {
    color: var(--sand-deep);
    flex-shrink: 0;
  }

  .event-header__website {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--green-deep);
    padding: var(--sp-2) var(--sp-4);
    border: 1px solid var(--green-wash);
    background: var(--green-tint);
    transition: all var(--duration-fast) var(--ease-out);
  }

  .event-header__website:hover {
    background: var(--green-wash);
    border-color: var(--green-soft);
  }

  /* ─── Body layout ──────────────────────────────────────── */

  .event-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-10);
  }

  @media (min-width: 64rem) {
    .event-body {
      grid-template-columns: 1fr 16rem;
      gap: var(--sp-12);
    }
  }

  .event-body__main {
    min-width: 0;
  }

  .event-body__sidebar {
    position: relative;
  }

  @media (min-width: 64rem) {
    .event-body__sidebar {
      position: sticky;
      top: var(--sp-8);
      align-self: start;
    }
  }

  /* ─── Sections ─────────────────────────────────────────── */

  .event-section {
    margin-bottom: var(--sp-10);
  }

  .event-section__label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--green);
    margin-bottom: var(--sp-4);
    padding-bottom: var(--sp-2);
    border-bottom: 1px solid var(--green-wash);
  }

  .event-section__text {
    font-family: var(--font-display);
    font-size: var(--text-md);
    line-height: 1.7;
    color: var(--charcoal-soft);
    max-width: 42em;
  }

  /* ─── Actor groups ─────────────────────────────────────── */

  .event-actors {
    display: flex;
    flex-direction: column;
    gap: var(--sp-8);
  }

  .event-actors__role {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--accent, var(--charcoal));
    margin-bottom: var(--sp-3);
    padding-left: var(--sp-3);
    border-left: 3px solid var(--accent, var(--green));
  }

  .event-actors__list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .event-actor-card {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    padding: var(--sp-4) var(--sp-5);
    background: var(--white);
    border: var(--border-subtle);
    text-decoration: none;
    color: inherit;
    transition: all var(--duration-normal) var(--ease-out);
  }

  .event-actor-card:hover {
    border-color: var(--green-soft);
    transform: translateX(4px);
    background: linear-gradient(to right, var(--green-tint), var(--white));
  }

  .event-actor-card__orient {
    width: 4px;
    height: 2rem;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .event-actor-card__info {
    flex: 1;
    min-width: 0;
  }

  .event-actor-card__name {
    font-family: var(--font-display);
    font-size: var(--text-base);
    color: var(--charcoal);
    line-height: 1.3;
  }

  .event-actor-card__meta {
    font-size: var(--text-sm);
    color: var(--zinc);
  }

  .event-actor-card__orientation {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.04em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ─── Sidebar card ─────────────────────────────────────── */

  .event-sidebar-card {
    background: var(--white);
    border: var(--border-subtle);
    padding: var(--sp-6);
    margin-bottom: var(--sp-6);
  }

  .event-sidebar-card__header {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding-bottom: var(--sp-4);
    margin-bottom: var(--sp-4);
    border-bottom: var(--border-subtle);
  }

  .event-sidebar-card__icon {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: var(--cream-dark);
    border: 1px solid var(--sand-warm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    color: var(--green);
  }

  .event-sidebar-card__type {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--charcoal);
  }

  .event-sidebar-card__field {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: var(--sp-2) 0;
    border-bottom: 1px dashed rgba(113, 113, 122, 0.1);
  }

  .event-sidebar-card__field:last-child {
    border-bottom: none;
  }

  .event-sidebar-card__label {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--zinc-light);
  }

  .event-sidebar-card__value {
    font-size: var(--text-sm);
    color: var(--charcoal);
    text-align: right;
  }

  /* ─── Related events ───────────────────────────────────── */

  .event-related {
    background: var(--white);
    border: var(--border-subtle);
    padding: var(--sp-5);
  }

  .event-related__label {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--green);
    margin-bottom: var(--sp-4);
  }

  .event-related__item {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-3);
    padding: var(--sp-3) 0;
    border-bottom: var(--border-subtle);
    text-decoration: none;
    color: inherit;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .event-related__item:last-child {
    border-bottom: none;
  }

  .event-related__item:hover {
    color: var(--green-deep);
  }

  .event-related__item:hover .event-related__icon {
    color: var(--green);
  }

  .event-related__icon {
    font-size: 0.65rem;
    color: var(--zinc-light);
    margin-top: 0.25rem;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .event-related__info {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .event-related__name {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    line-height: 1.3;
  }

  .event-related__meta {
    font-size: var(--text-xs);
    color: var(--zinc-light);
  }

  /* ─── Responsive ───────────────────────────────────────── */

  @media (max-width: 40rem) {
    .event-header__title {
      font-size: 1.8rem;
    }

    .event-header__icon-ring {
      width: 2.8rem;
      height: 2.8rem;
    }
  }
</style>
