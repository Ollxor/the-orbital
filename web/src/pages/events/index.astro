---
import Base from '../../layouts/Base.astro';
import { getAllEvents, ORIENTATION_COLORS, EVENT_TYPE_ICONS } from '../../lib/db';

const events = getAllEvents();

// Group events by time period
interface TimeGroup {
  label: string;
  sublabel: string;
  events: typeof events;
}

function getYear(dateStr: string | null): string {
  if (!dateStr) return 'undated';
  if (dateStr === 'upcoming') return 'upcoming';
  return dateStr.substring(0, 4);
}

function getMonthName(dateStr: string | null): string | null {
  if (!dateStr || dateStr === 'upcoming' || dateStr.length <= 4) return null;
  const monthNum = parseInt(dateStr.substring(5, 7));
  const months = ['', 'January', 'February', 'March', 'April', 'May', 'June',
                  'July', 'August', 'September', 'October', 'November', 'December'];
  return months[monthNum] || null;
}

function formatDateDisplay(dateStr: string | null): string {
  if (!dateStr) return 'Date TBD';
  if (dateStr === 'upcoming') return 'Upcoming';
  const month = getMonthName(dateStr);
  const year = dateStr.substring(0, 4);
  if (month) return `${month} ${year}`;
  return year;
}

// Build time groups
const groupMap = new Map<string, TimeGroup>();
const groupOrder: string[] = [];

for (const evt of events) {
  const year = getYear(evt.date_start);
  let key: string;
  let label: string;
  let sublabel: string;

  if (year === 'upcoming') {
    key = '0_upcoming';
    label = 'Upcoming';
    sublabel = 'Confirmed future events';
  } else if (year === 'undated') {
    key = '2_undated';
    label = 'Ongoing & Undated';
    sublabel = 'Recurring or date not yet confirmed';
  } else {
    key = `1_${year}`;
    label = year;
    sublabel = `${year} events`;
  }

  if (!groupMap.has(key)) {
    groupMap.set(key, { label, sublabel, events: [] });
    groupOrder.push(key);
  }
  groupMap.get(key)!.events.push(evt);
}

// Sort: upcoming first, then years desc, undated last
groupOrder.sort((a, b) => {
  if (a.startsWith('0_')) return -1;
  if (b.startsWith('0_')) return 1;
  if (a.startsWith('2_')) return 1;
  if (b.startsWith('2_')) return -1;
  return b.localeCompare(a);
});

const groups = groupOrder.map(k => groupMap.get(k)!);

// Stats
const totalEvents = events.length;
const withDates = events.filter(e => e.date_start && e.date_start !== 'upcoming').length;
const seriesCount = new Set(events.filter(e => e.series).map(e => e.series)).size;
const typeBreakdown = events.reduce((acc, e) => {
  const t = e.type || 'Other';
  acc[t] = (acc[t] || 0) + 1;
  return acc;
}, {} as Record<string, number>);
const topTypes = Object.entries(typeBreakdown).sort((a, b) => b[1] - a[1]).slice(0, 5);
---
<Base title="Events" currentPath="/events">
  <!-- Hero -->
  <div class="events-hero reveal reveal-1">
    <div class="events-hero__eyebrow">Event Calendar</div>
    <h1 class="events-hero__title">
      Where the<br/>landscape <em>gathers</em>
    </h1>
    <p class="events-hero__description">
      Conferences, summits, festivals, workshops, and assemblies where planetary governance
      is discussed, prototyped, and practised. Tracking {totalEvents} events across {seriesCount} recurring series.
    </p>
  </div>

  <!-- Type pills -->
  <div class="events-type-bar reveal reveal-2">
    {topTypes.map(([type, count]) => (
      <span class="events-type-pill">
        <span class="events-type-pill__icon">{EVENT_TYPE_ICONS[type] || '\u25CB'}</span>
        <span class="events-type-pill__label">{type}</span>
        <span class="events-type-pill__count">{count}</span>
      </span>
    ))}
  </div>

  <!-- Timeline -->
  <div class="timeline">
    {groups.map((group, gi) => (
      <section class={`timeline__group reveal reveal-${Math.min(gi + 2, 6)}`}>
        <div class="timeline__year-marker">
          <div class="timeline__year-label">{group.label}</div>
          <div class="timeline__year-rule"></div>
        </div>

        <div class="timeline__events">
          {group.events.map((evt, ei) => {
            const icon = EVENT_TYPE_ICONS[evt.type || 'Other'] || '\u25CB';
            const month = getMonthName(evt.date_start);
            return (
              <a href={`/events/${evt.id}`} class="timeline-card" style={`--delay: ${ei * 40}ms`}>
                <div class="timeline-card__spine">
                  <div class="timeline-card__node" title={evt.type || 'Event'}>{icon}</div>
                  <div class="timeline-card__line"></div>
                </div>
                <div class="timeline-card__content">
                  <div class="timeline-card__date-row">
                    {month && <span class="timeline-card__month">{month}</span>}
                    {evt.type && <span class="timeline-card__type">{evt.type}</span>}
                    {evt.series && <span class="timeline-card__series">{evt.series}</span>}
                  </div>
                  <h3 class="timeline-card__title">{evt.name}</h3>
                  <div class="timeline-card__meta">
                    {evt.location && (
                      <span class="timeline-card__location">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                          <circle cx="12" cy="9" r="2.5"/>
                        </svg>
                        {evt.location}
                      </span>
                    )}
                    {evt.recurrence && evt.recurrence !== 'one-off' && (
                      <span class="timeline-card__recurrence">{evt.recurrence}</span>
                    )}
                    {(evt.actor_count ?? 0) > 0 && (
                      <span class="timeline-card__actors">
                        {evt.actor_count} actor{evt.actor_count !== 1 ? 's' : ''}
                      </span>
                    )}
                  </div>
                  {evt.description && (
                    <p class="timeline-card__description">{evt.description}</p>
                  )}
                </div>
                <div class="timeline-card__arrow">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M9 18l6-6-6-6"/>
                  </svg>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    ))}
  </div>

  <!-- Empty state -->
  {events.length === 0 && (
    <div class="empty" style="text-align:center;padding:var(--sp-20) 0">
      <p style="font-family:var(--font-display);font-size:var(--text-xl);color:var(--zinc)">
        No events yet. Run <code>python3 parse_events.py --commit</code> to populate.
      </p>
    </div>
  )}
</Base>

<style>
  /* ═══════════════════════════════════════════════════════
     EVENTS TIMELINE — Editorial Calendar
     ═══════════════════════════════════════════════════════ */

  /* ─── Hero ─────────────────────────────────────────────── */

  .events-hero {
    max-width: 44rem;
    margin-bottom: var(--sp-12);
  }

  .events-hero__eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--green);
    margin-bottom: var(--sp-4);
  }

  .events-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 300;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--charcoal);
    margin-bottom: var(--sp-6);
  }

  .events-hero__title em {
    font-style: italic;
    color: var(--green);
  }

  .events-hero__description {
    font-family: var(--font-display);
    font-size: var(--text-md);
    font-weight: 300;
    line-height: 1.7;
    color: var(--zinc);
    max-width: 36em;
  }

  /* ─── Type bar ─────────────────────────────────────────── */

  .events-type-bar {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin-bottom: var(--sp-16);
    padding-bottom: var(--sp-8);
    border-bottom: 2px solid var(--green-wash);
  }

  .events-type-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-4);
    background: var(--white);
    border: var(--border-subtle);
    font-size: var(--text-sm);
    color: var(--charcoal-soft);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .events-type-pill__icon {
    font-size: 0.7em;
    color: var(--green);
  }

  .events-type-pill__label {
    font-weight: 400;
  }

  .events-type-pill__count {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--zinc-light);
  }

  /* ─── Timeline ─────────────────────────────────────────── */

  .timeline {
    max-width: 56rem;
  }

  .timeline__group {
    margin-bottom: var(--sp-16);
  }

  .timeline__group:last-child {
    margin-bottom: 0;
  }

  /* ─── Year marker ──────────────────────────────────────── */

  .timeline__year-marker {
    display: flex;
    align-items: center;
    gap: var(--sp-6);
    margin-bottom: var(--sp-8);
  }

  .timeline__year-label {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 300;
    letter-spacing: -0.02em;
    color: var(--charcoal);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .timeline__year-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--sand-warm), transparent);
  }

  /* ─── Event list ───────────────────────────────────────── */

  .timeline__events {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ─── Timeline card ────────────────────────────────────── */

  .timeline-card {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    gap: 0 var(--sp-5);
    padding: var(--sp-6) 0;
    text-decoration: none;
    color: inherit;
    border-bottom: var(--border-subtle);
    transition: background var(--duration-normal) var(--ease-out);
    position: relative;
    animation: timeline-fadeIn 0.5s var(--ease-out) var(--delay, 0ms) both;
  }

  .timeline-card:first-child {
    border-top: var(--border-subtle);
  }

  .timeline-card:hover {
    background: linear-gradient(to right, var(--green-tint), transparent 70%);
  }

  .timeline-card:hover .timeline-card__node {
    background: var(--green);
    color: var(--white);
    transform: scale(1.15);
  }

  .timeline-card:hover .timeline-card__title {
    color: var(--green-deep);
  }

  .timeline-card:hover .timeline-card__arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* ─── Spine ────────────────────────────────────────────── */

  .timeline-card__spine {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: var(--sp-1);
  }

  .timeline-card__node {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: var(--cream-dark);
    border: 2px solid var(--sand-warm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    color: var(--charcoal-soft);
    flex-shrink: 0;
    transition: all var(--duration-normal) var(--ease-out);
    z-index: 1;
  }

  .timeline-card__line {
    width: 1px;
    flex: 1;
    background: linear-gradient(to bottom, var(--sand-warm), transparent);
    margin-top: var(--sp-2);
  }

  /* ─── Content ──────────────────────────────────────────── */

  .timeline-card__content {
    min-width: 0;
  }

  .timeline-card__date-row {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-bottom: var(--sp-2);
    flex-wrap: wrap;
  }

  .timeline-card__month {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--green);
  }

  .timeline-card__type {
    font-size: var(--text-xs);
    color: var(--zinc);
    padding: 1px var(--sp-2);
    background: var(--cream-dark);
    border: var(--border-subtle);
  }

  .timeline-card__series {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--sand-deep);
    letter-spacing: 0.02em;
  }

  .timeline-card__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--charcoal);
    margin-bottom: var(--sp-2);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .timeline-card__meta {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    flex-wrap: wrap;
    font-size: var(--text-sm);
    color: var(--zinc);
    margin-bottom: var(--sp-2);
  }

  .timeline-card__location {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
  }

  .timeline-card__location svg {
    color: var(--sand-deep);
    flex-shrink: 0;
  }

  .timeline-card__recurrence {
    font-style: italic;
    font-family: var(--font-display);
    color: var(--zinc-light);
  }

  .timeline-card__actors {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--zinc-light);
  }

  .timeline-card__description {
    font-size: var(--text-sm);
    color: var(--charcoal-soft);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 0;
  }

  /* ─── Arrow ────────────────────────────────────────────── */

  .timeline-card__arrow {
    display: flex;
    align-items: center;
    color: var(--green);
    opacity: 0;
    transform: translateX(-4px);
    transition: all var(--duration-normal) var(--ease-out);
  }

  /* ─── Animations ───────────────────────────────────────── */

  @keyframes timeline-fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ─── Responsive ───────────────────────────────────────── */

  @media (max-width: 40rem) {
    .timeline-card {
      grid-template-columns: 1.8rem 1fr;
    }

    .timeline-card__arrow {
      display: none;
    }

    .timeline-card__node {
      width: 1.5rem;
      height: 1.5rem;
      font-size: 0.5rem;
    }

    .timeline-card__title {
      font-size: var(--text-lg);
    }

    .events-hero__title {
      font-size: 2rem;
    }
  }
</style>
