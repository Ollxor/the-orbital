---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import {
  getAllProjects, getProject, getProjectActors, getProjectSources, getProjectIntel,
  getProjectImages, getProjectTags, ORIENTATION_COLORS,
} from '../../lib/db';

export function getStaticPaths() {
  const projects = getAllProjects();
  return projects.map(p => ({ params: { id: String(p.id) } }));
}

const { id } = Astro.params;
const projectId = Number(id);
const project = getProject(projectId);

if (!project) return Astro.redirect('/projects');

const actors = getProjectActors(projectId);
const sources = getProjectSources(projectId);
const intel = getProjectIntel(projectId);
const images = getProjectImages(projectId);
const tags = getProjectTags(projectId);

const allNews = await getCollection('news');
const relatedNews = allNews
  .filter(n => n.data.projects.includes(projectId))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---
<Base title={project.name}>
  <a href="/projects" class="back-link">Projects</a>

  <div class="dossier-header reveal reveal-1">
    <div class="dossier-header__bar" style="background: var(--sand-warm)"></div>
    <div class="dossier-header__ref">GP-{String(project.id).padStart(3, '0')}</div>
    <h1 class="dossier-header__title">{project.name}</h1>
    <div class="dossier-header__subtitle">
      {project.stage && <span class="badge">{project.stage}</span>}
      {project.geography && <span class="meta">{project.geography}</span>}
    </div>
    {project.description && (
      <p class="dossier-header__description">{project.description}</p>
    )}
  </div>

  <div class="dossier reveal reveal-2">
    <aside class="dossier__sidebar">
      {project.stage && (
        <div class="dossier__sidebar-section">
          <div class="dossier__sidebar-label">Stage</div>
          <div class="dossier__sidebar-value">{project.stage}</div>
        </div>
      )}

      {project.geography && (
        <div class="dossier__sidebar-section">
          <div class="dossier__sidebar-label">Geography</div>
          <div class="dossier__sidebar-value">{project.geography}</div>
        </div>
      )}

      {project.website && (
        <div class="dossier__sidebar-section">
          <div class="dossier__sidebar-label">Website</div>
          <a href={project.website} target="_blank" rel="noopener"
            style="font-size:var(--text-sm);word-break:break-all">
            {new URL(project.website).hostname}
          </a>
        </div>
      )}

      {tags.length > 0 && (
        <div class="dossier__sidebar-section">
          <div class="dossier__sidebar-label">Tags</div>
          <div style="display:flex;flex-wrap:wrap;gap:0.375rem;margin-top:0.25rem">
            {tags.map(tag => (
              <a href={`/tags/${tag.name}`} class="chip" style="font-size:var(--text-xs)">{tag.name}</a>
            ))}
          </div>
        </div>
      )}

      {sources.length > 0 && (
        <div class="dossier__sidebar-section">
          <div class="dossier__sidebar-label">Sources</div>
          <ul class="source-list">
            {sources.map(src => (
              <li class="source-list__item">
                <a href={src.url} target="_blank" rel="noopener"
                  style="font-size:var(--text-sm)">
                  {src.title || src.url}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </aside>

    <div class="dossier__main">
      {intel.length > 0 && (
        <div class="section reveal reveal-3">
          <div class="section-heading">Intelligence</div>
          <div class="card-grid card-grid--2" style="gap:0.75rem">
            {intel.map(item => (
              <div class="intel-card">
                <div class="intel-card__field">{item.field}</div>
                <div class="intel-card__value">{item.value}</div>
                <div class="intel-card__confidence">{item.confidence}</div>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Gallery */}
      {images.length > 0 && (
        <div class="section reveal reveal-3" x-data={`{ lightbox: false, current: 0, images: ${JSON.stringify(images.map(img => ({ src: '/images/projects/' + img.filename, alt: img.alt_text || '', caption: img.caption || '' })))} }`}>
          <div class="section-heading">Gallery</div>
          <div class="gallery">
            {images.map((img, i) => (
              <div class="gallery__item" @click={`lightbox = true; current = ${i}`}>
                <img src={`/images/projects/${img.filename}`} alt={img.alt_text || ''} class="gallery__img" loading="lazy" />
                {img.caption && <div class="gallery__caption">{img.caption}</div>}
              </div>
            ))}
          </div>
          <template x-if="lightbox">
            <div class="lightbox" @click.self="lightbox = false" @keydown.escape.window="lightbox = false">
              <button class="lightbox__close" @click="lightbox = false">&times;</button>
              <button class="lightbox__nav lightbox__nav--prev" @click="current = (current - 1 + images.length) % images.length" x-show="images.length > 1">&lsaquo;</button>
              <img :src="images[current].src" :alt="images[current].alt" class="lightbox__img" />
              <button class="lightbox__nav lightbox__nav--next" @click="current = (current + 1) % images.length" x-show="images.length > 1">&rsaquo;</button>
              <div class="lightbox__caption" x-text="images[current].caption" x-show="images[current].caption"></div>
            </div>
          </template>
        </div>
      )}

      {actors.length > 0 && (
        <div class="section reveal reveal-3">
          <div class="section-heading">Connected Actors</div>
          <div class="card-grid card-grid--2" style="gap:0.75rem">
            {actors.map(actor => {
              const color = actor.orientation_code ? ORIENTATION_COLORS[actor.orientation_code] || '#71717a' : '#71717a';
              return (
                <a href={`/actors/${actor.id}`} class="card card--link" style="padding:var(--sp-4) var(--sp-5)">
                  <div style={`display:flex;align-items:center;gap:0.4rem;margin-bottom:0.25rem`}>
                    <span style={`width:4px;height:4px;border-radius:50%;background:${color}`}></span>
                    <span class="badge badge--type" style="font-size:0.6rem">{actor.type}</span>
                    {actor.relationship && <span class="meta" style="margin-left:auto;font-style:italic">{actor.relationship}</span>}
                  </div>
                  <div style="font-family:var(--font-display);font-size:var(--text-base);line-height:1.3">{actor.name}</div>
                  {actor.location && <div class="meta" style="margin-top:0.25rem">{actor.location}</div>}
                </a>
              );
            })}
          </div>
        </div>
      )}

      {relatedNews.length > 0 && (
        <div class="section reveal reveal-4">
          <div class="section-heading">From the Field</div>
          {relatedNews.map(story => (
            <article class="news-card">
              <div class="news-card__date">{formatDate(story.data.date)}</div>
              <h3 class="news-card__title" style="font-size:var(--text-lg)">
                <a href={`/news/${story.id}`}>{story.data.title}</a>
              </h3>
              <p class="news-card__summary" style="font-size:var(--text-sm)">{story.data.summary}</p>
            </article>
          ))}
        </div>
      )}

      {project.notes && (
        <div class="section reveal reveal-5">
          <div class="section-heading">Notes</div>
          <p class="meta" style="font-style:italic;line-height:1.7">{project.notes}</p>
        </div>
      )}
    </div>
  </div>
</Base>
