---
import Base from '../../layouts/Base.astro';
import { getAllProjects } from '../../lib/db';

const projects = getAllProjects();

const stages = ['Early', 'Active', 'Scaled'];
const STAGE_ORDER = ['research', 'pilot', 'deployed', 'scaled', 'Early', 'Active', 'Scaled'];

function stageIndex(s: string | null): number {
  if (!s) return -1;
  const idx = STAGE_ORDER.indexOf(s);
  return idx >= 0 ? idx : -1;
}
---
<Base title="Projects" currentPath="/projects">
  <h1 class="page-title">Projects</h1>
  <p class="page-subtitle">
    Specific initiatives, platforms, and programs operating within the landscape
  </p>

  <div style="display:flex;flex-direction:column;gap:0.75rem">
    {projects.map(project => (
      <a href={`/projects/${project.id}`} class="card card--link" style="padding:var(--sp-5) var(--sp-6)">
        <div style="display:flex;justify-content:space-between;align-items:baseline;gap:1rem;flex-wrap:wrap">
          <div>
            <div class="card__title">{project.name}</div>
            {project.geography && <div class="meta">{project.geography}</div>}
          </div>
          <div style="display:flex;align-items:center;gap:1rem;flex-shrink:0">
            {project.actor_count ? (
              <span class="meta">{project.actor_count} actor{project.actor_count !== 1 ? 's' : ''}</span>
            ) : null}
            {project.stage && (
              <span class="badge">{project.stage}</span>
            )}
          </div>
        </div>
        {project.description && (
          <p class="card__description" style="margin-top:0.5rem">{project.description}</p>
        )}
      </a>
    ))}
  </div>
</Base>
