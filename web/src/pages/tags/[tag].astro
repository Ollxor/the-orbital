---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getActor, getAllTags, getTagActors, getTagProjects, getTagPeople, ORIENTATION_COLORS } from '../../lib/db';

export async function getStaticPaths() {
  const news = await getCollection('news');
  const tagSet = new Set<string>();
  for (const story of news) {
    for (const tag of story.data.tags) {
      tagSet.add(tag);
    }
  }
  // Also include DB-only tags
  const dbTags = getAllTags();
  for (const t of dbTags) {
    tagSet.add(t.name);
  }
  return [...tagSet].map(tag => ({ params: { tag } }));
}

const { tag } = Astro.params;

// News stories with this tag
const allNews = await getCollection('news');
const stories = allNews
  .filter(n => n.data.tags.includes(tag!))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// DB entities with this tag
const taggedActors = getTagActors(tag!);
const taggedProjects = getTagProjects(tag!);
const taggedPeople = getTagPeople(tag!);

// Collect all related tags (co-occurring with this tag in news)
const relatedTags = new Map<string, number>();
for (const story of stories) {
  for (const t of story.data.tags) {
    if (t !== tag) {
      relatedTags.set(t, (relatedTags.get(t) || 0) + 1);
    }
  }
}
const sortedRelated = [...relatedTags.entries()].sort((a, b) => b[1] - a[1]);

// Pre-resolve actor links per story
function getActorNames(actorIds: number[]): { id: number; name: string }[] {
  return actorIds
    .map(id => {
      const actor = getActor(id);
      return actor ? { id: actor.id, name: actor.name } : null;
    })
    .filter((a): a is { id: number; name: string } => a !== null);
}

const storiesWithActors = stories.map(story => ({
  story,
  actorLinks: getActorNames(story.data.actors),
}));

const totalEntities = taggedActors.length + taggedProjects.length + taggedPeople.length + stories.length;

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---
<Base title={`Tag: ${tag}`}>
  <a href="/tags" class="back-link">Tags</a>

  <div class="dossier-header reveal reveal-1">
    <div class="dossier-header__bar" style="background: var(--green-deep)"></div>
    <h1 class="dossier-header__title">{tag}</h1>
    <div class="dossier-header__subtitle">
      <span class="meta">{totalEntities} connected {totalEntities === 1 ? 'entity' : 'entities'}</span>
    </div>
  </div>

  <div class="dossier reveal reveal-2">
    <aside class="dossier__sidebar">
      {sortedRelated.length > 0 && (
        <div class="dossier__sidebar-section">
          <div class="dossier__sidebar-label">Related Tags</div>
          <div style="display:flex;flex-wrap:wrap;gap:0.375rem;margin-top:0.25rem">
            {sortedRelated.map(([t, count]) => (
              <a href={`/tags/${t}`} class="chip" style="font-size:var(--text-xs)">
                {t}
                <span style="opacity:0.5;margin-left:0.2rem">{count}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="dossier__sidebar-section">
        <div class="dossier__sidebar-label">Breakdown</div>
        <div style="display:flex;flex-direction:column;gap:0.25rem;margin-top:0.25rem;font-size:var(--text-sm)">
          {taggedActors.length > 0 && <span>{taggedActors.length} actors</span>}
          {taggedProjects.length > 0 && <span>{taggedProjects.length} projects</span>}
          {taggedPeople.length > 0 && <span>{taggedPeople.length} people</span>}
          {stories.length > 0 && <span>{stories.length} stories</span>}
        </div>
      </div>
    </aside>

    <div class="dossier__main">
      {taggedActors.length > 0 && (
        <div class="section reveal reveal-3">
          <div class="section-heading">Actors</div>
          <div class="card-grid card-grid--2" style="gap:0.75rem">
            {taggedActors.map(actor => {
              const color = actor.orientation_code ? ORIENTATION_COLORS[actor.orientation_code] || '#71717a' : '#71717a';
              return (
                <a href={`/actors/${actor.id}`} class="card card--link" style="padding:var(--sp-4) var(--sp-5)">
                  <div style="display:flex;align-items:center;gap:0.4rem;margin-bottom:0.25rem">
                    <span style={`width:4px;height:4px;border-radius:50%;background:${color}`}></span>
                    <span class="badge badge--type" style="font-size:0.6rem">{actor.type}</span>
                  </div>
                  <div style="font-family:var(--font-display);font-size:var(--text-base);line-height:1.3">{actor.name}</div>
                  {actor.description && (
                    <div class="meta" style="margin-top:0.25rem;font-size:var(--text-xs);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">
                      {actor.description}
                    </div>
                  )}
                </a>
              );
            })}
          </div>
        </div>
      )}

      {taggedProjects.length > 0 && (
        <div class="section reveal reveal-3">
          <div class="section-heading">Projects</div>
          <div style="display:flex;flex-direction:column;gap:0.5rem">
            {taggedProjects.map(project => (
              <a href={`/projects/${project.id}`} class="card card--link" style="padding:var(--sp-4) var(--sp-5)">
                <div style="display:flex;justify-content:space-between;align-items:baseline;gap:1rem">
                  <span class="card__title" style="font-size:var(--text-base);margin-bottom:0">{project.name}</span>
                  {project.stage && <span class="badge">{project.stage}</span>}
                </div>
                {project.geography && <div class="meta" style="margin-top:0.25rem">{project.geography}</div>}
              </a>
            ))}
          </div>
        </div>
      )}

      {taggedPeople.length > 0 && (
        <div class="section reveal reveal-4">
          <div class="section-heading">People</div>
          <div class="connected-grid">
            {taggedPeople.map(person => (
              <a href={`/people/${person.id}`} class="person-card">
                <span class="person-card__name">
                  {person.first_name} {person.last_name}
                </span>
                {person.job_title && <span class="person-card__detail">{person.job_title}</span>}
              </a>
            ))}
          </div>
        </div>
      )}

      {stories.length > 0 && (
        <div class="section reveal reveal-5">
          <div class="section-heading">Stories</div>
          {storiesWithActors.map(({ story, actorLinks }) => (
              <article class="news-card">
                {story.data.image && (
                  <a href={`/news/${story.id}`}>
                    <img src={story.data.image} alt={story.data.imageAlt || ''} class="news-card__image" loading="lazy" />
                  </a>
                )}
                <div class="news-card__date">{formatDate(story.data.date)}</div>
                <h3 class="news-card__title">
                  <a href={`/news/${story.id}`}>{story.data.title}</a>
                </h3>
                <p class="news-card__summary">{story.data.summary}</p>
                <div class="news-card__tags">
                  {actorLinks.map(actor => (
                    <a href={`/actors/${actor.id}`} class="chip">{actor.name}</a>
                  ))}
                  {story.data.tags.map(t => (
                    <a href={`/tags/${t}`} class={`chip ${t === tag ? 'chip--active' : ''}`}>{t}</a>
                  ))}
                </div>
              </article>
          ))}
        </div>
      )}
    </div>
  </div>
</Base>
